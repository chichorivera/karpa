---
import '../styles/global.css'

interface Props { title: string; active?: string }
const { title, active = '' } = Astro.props

const nav = [
  { href: '/admin/dashboard', label: 'Dashboard' },
  { href: '/admin/campings',  label: 'Campings' },
  { href: '/admin/users',     label: 'Usuarios' },
  { href: '/admin/bookings',  label: 'Reservas' },
  { href: '/admin/reviews',   label: 'Reseñas' },
]
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Karpa Admin</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased min-h-screen" style="background-color:#faf8f5;font-family:'Inter',sans-serif">
    <div class="flex min-h-screen">

      <!-- Sidebar desktop -->
      <aside class="hidden lg:flex flex-col w-64 bg-white border-r fixed inset-y-0 left-0 z-30" style="border-color:#e8ddd4">
        <div class="px-6 py-5 border-b" style="border-color:#e8ddd4">
          <a href="/" class="flex items-center gap-2">
            <span class="text-xl font-bold" style="font-family:'Playfair Display',serif;color:#6D4C3D">Karpa</span>
            <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background-color:#6D4C3D">Admin</span>
          </a>
        </div>
        <nav class="flex-1 px-3 py-6 space-y-1">
          {nav.map(item => (
            <a href={item.href}
               class={`flex items-center px-3 py-2.5 rounded-xl text-sm font-medium transition ${active === item.href ? 'text-white' : 'text-gray-600 hover:text-[#6D4C3D]'}`}
               style={active === item.href ? 'background-color:#6D4C3D' : ''}>
              {item.label}
            </a>
          ))}
        </nav>
        <div class="px-3 py-4 border-t" style="border-color:#e8ddd4">
          <form action="/api/auth/logout" method="POST">
            <button class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-red-50 hover:text-red-600 transition w-full">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
              </svg>
              Cerrar sesión
            </button>
          </form>
        </div>
      </aside>

      <!-- Mobile header -->
      <header class="lg:hidden fixed top-0 inset-x-0 z-30 bg-white border-b px-4 h-14 flex items-center justify-between" style="border-color:#e8ddd4">
        <div class="flex items-center gap-2">
          <span class="text-lg font-bold" style="font-family:'Playfair Display',serif;color:#6D4C3D">Karpa</span>
          <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background-color:#6D4C3D">Admin</span>
        </div>
        <button id="menu-btn" class="p-2 rounded-lg hover:bg-gray-100">
          <svg class="w-5 h-5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </header>

      <!-- Mobile drawer -->
      <div id="mobile-nav" class="lg:hidden fixed inset-0 z-40 hidden">
        <div class="absolute inset-0 bg-black/30" id="nav-overlay"></div>
        <aside class="absolute left-0 top-0 bottom-0 w-64 bg-white flex flex-col shadow-xl">
          <div class="px-6 py-5 border-b flex items-center justify-between" style="border-color:#e8ddd4">
            <div class="flex items-center gap-2">
              <span class="text-xl font-bold" style="font-family:'Playfair Display',serif;color:#6D4C3D">Karpa</span>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium text-white" style="background-color:#6D4C3D">Admin</span>
            </div>
            <button id="close-nav" class="p-1 rounded-lg hover:bg-gray-100">
              <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <nav class="flex-1 px-3 py-6 space-y-1">
            {nav.map(item => (
              <a href={item.href} class={`flex items-center px-3 py-2.5 rounded-xl text-sm font-medium transition ${active === item.href ? 'text-white' : 'text-gray-600 hover:bg-[#F4E8D4]'}`}
                 style={active === item.href ? 'background-color:#6D4C3D' : ''}>
                {item.label}
              </a>
            ))}
          </nav>
          <div class="px-3 py-4 border-t" style="border-color:#e8ddd4">
            <form action="/api/auth/logout" method="POST">
              <button class="flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-red-50 hover:text-red-600 transition w-full">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Cerrar sesión
              </button>
            </form>
          </div>
        </aside>
      </div>

      <main class="flex-1 lg:ml-64">
        <div class="pt-14 lg:pt-0">
          <div class="hidden lg:flex items-center px-8 py-5 bg-white border-b" style="border-color:#e8ddd4">
            <h1 class="text-xl font-bold text-gray-900" style="font-family:'Playfair Display',serif">{title}</h1>
          </div>
          <div class="px-4 lg:px-8 py-6 lg:py-8"><slot /></div>
        </div>
      </main>
    </div>

    <script>
      const btn     = document.getElementById('menu-btn')
      const nav     = document.getElementById('mobile-nav')
      const overlay = document.getElementById('nav-overlay')
      const close   = document.getElementById('close-nav')
      btn?.addEventListener('click',     () => nav?.classList.remove('hidden'))
      overlay?.addEventListener('click', () => nav?.classList.add('hidden'))
      close?.addEventListener('click',   () => nav?.classList.add('hidden'))
    </script>
  </body>
</html>
