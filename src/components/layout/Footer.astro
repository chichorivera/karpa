---
---
<footer class="border-t mt-20" style="border-color:#e8ddd4;background-color:#faf8f5">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid sm:grid-cols-3 gap-8 mb-10">
      <div>
        <a href="/"><img src="/logo-karpa.png" alt="Karpa" class="h-10 w-auto mb-3" /></a>
        <p class="text-sm text-gray-500 leading-relaxed">
          El marketplace de campings en Chile. Encuentra tu próxima aventura.
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-800 mb-3">Explora</p>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="/search" class="hover:text-[#6D4C3D] transition">Buscar campings</a></li>
          <li><a href="/search?type=glamping" class="hover:text-[#6D4C3D] transition">Glamping</a></li>
          <li><a href="/search?type=cabin" class="hover:text-[#6D4C3D] transition">Cabañas</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-800 mb-3">Publica tu camping</p>
        <ul class="space-y-2 text-sm text-gray-500">
          <li><a href="/auth/register?role=host" class="hover:text-[#6D4C3D] transition">Crear cuenta Host</a></li>
          <li><a href="/terminos" class="hover:text-[#6D4C3D] transition">Términos de uso</a></li>
          <li><a href="/privacidad" class="hover:text-[#6D4C3D] transition">Privacidad</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-400" style="border-color:#e8ddd4">
      <p>© {new Date().getFullYear()} Karpa. Todos los derechos reservados.</p>
      <p>Hecho con ♥ en Chile</p>
    </div>
  </div>
</footer>
