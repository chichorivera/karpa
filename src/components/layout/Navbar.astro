---
interface Props {
  transparent?: boolean
}
const { transparent = false } = Astro.props
---

<nav
  id="navbar"
  class={`fixed top-0 inset-x-0 z-50 transition-all duration-300 ${
    transparent ? 'bg-transparent' : 'bg-white border-b'
  }`}
  style={transparent ? '' : 'border-color:#e8ddd4'}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="shrink-0">
      <span
        class={`text-2xl font-bold transition-colors ${transparent ? 'text-white' : ''}`}
        style={transparent ? '' : 'color:#6D4C3D'}
        id="nav-logo"
        data-transparent={transparent}
        style="font-family:'Playfair Display',serif"
      >
        Karpa
      </span>
    </a>

    <!-- Buscador compacto (solo en páginas internas) -->
    {!transparent && (
      <form action="/search" method="GET"
        class="hidden md:flex items-center gap-0 bg-gray-50 border rounded-full px-4 py-2 flex-1 max-w-sm"
        style="border-color:#D9C3A5">
        <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
        </svg>
        <input
          name="q" type="text" placeholder="¿A dónde vas?"
          class="flex-1 bg-transparent text-sm outline-none px-2 placeholder:text-gray-400"
        />
      </form>
    )}

    <!-- Actions -->
    <div class="flex items-center gap-2 shrink-0">
      <a href="/auth/login"
        class={`hidden sm:inline-block px-4 py-2 rounded-xl text-sm font-medium transition ${
          transparent
            ? 'text-white hover:bg-white/20'
            : 'text-gray-700 hover:bg-gray-100'
        }`}>
        Iniciar sesión
      </a>
      <a href="/auth/register"
        class="px-4 py-2 rounded-xl text-white text-sm font-semibold transition hover:opacity-90"
        style="background-color:#6D4C3D">
        Registro
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')
  const logo   = document.getElementById('nav-logo')
  const isTransparent = logo?.dataset.transparent === 'true'

  if (isTransparent && navbar) {
    const update = () => {
      const scrolled = window.scrollY > 60
      navbar.classList.toggle('bg-white',   scrolled)
      navbar.classList.toggle('border-b',   scrolled)
      navbar.classList.toggle('bg-transparent', !scrolled)
      navbar.classList.toggle('shadow-sm',  scrolled)
      if (logo) {
        logo.style.color = scrolled ? '#6D4C3D' : ''
        logo.classList.toggle('text-white', !scrolled)
      }
    }
    window.addEventListener('scroll', update, { passive: true })
    update()
  }
</script>
