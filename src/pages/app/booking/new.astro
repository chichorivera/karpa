---
import PublicLayout from '../../../layouts/PublicLayout.astro'
import Navbar from '../../../components/layout/Navbar.astro'
import { supabase } from '../../../lib/supabase'

const unitId    = Astro.url.searchParams.get('unit') ?? ''
const campingId = Astro.url.searchParams.get('camping') ?? ''
const checkin   = Astro.url.searchParams.get('checkin') ?? ''
const checkout  = Astro.url.searchParams.get('checkout') ?? ''

if (!unitId || !campingId) return Astro.redirect('/')

const { data: unit } = await supabase
  .from('units')
  .select('id, name, type, capacity, price_per_night, camping_id, campings(id, name, slug, city)')
  .eq('id', unitId)
  .single()

if (!unit) return Astro.redirect('/')

const camping = (unit as any).campings

const nights = checkin && checkout
  ? Math.max(1, Math.round((new Date(checkout).getTime() - new Date(checkin).getTime()) / 86400000))
  : 1

const total = Number(unit.price_per_night) * nights

const unitTypeLabel: Record<string, string> = {
  tent: 'Carpa', cabin: 'Cabaña', glamping: 'Glamping', camper: 'Camper', other: 'Otro',
}
---

<PublicLayout title={`Reservar — ${unit.name}`}>
  <Navbar />

  <main class="pt-24 pb-16 max-w-3xl mx-auto px-4">
    <a href={`/camping/${camping?.slug}`}
       class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-8 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver al camping
    </a>

    <h1 class="text-3xl font-bold text-gray-900 mb-8" style="font-family:'Playfair Display',serif">
      Confirma tu reserva
    </h1>

    <div class="grid sm:grid-cols-2 gap-8">

      <!-- Formulario -->
      <form id="booking-form" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="checkin">Check-in</label>
          <input id="checkin" name="checkin" type="date" required
            value={checkin}
            min={new Date().toISOString().split('T')[0]}
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition focus:ring-2 focus:ring-[#6D4C3D]/10"
            style="border-color:#D9C3A5" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="checkout">Check-out</label>
          <input id="checkout" name="checkout" type="date" required
            value={checkout}
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition focus:ring-2 focus:ring-[#6D4C3D]/10"
            style="border-color:#D9C3A5" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="guests">
            Huéspedes (máx. {unit.capacity})
          </label>
          <select id="guests" name="guests"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition"
            style="border-color:#D9C3A5">
            {Array.from({ length: unit.capacity }, (_, i) => i + 1).map(n => (
              <option value={n}>{n} persona{n !== 1 ? 's' : ''}</option>
            ))}
          </select>
        </div>

        <div id="price-summary" class="rounded-xl p-4 space-y-2" style="background-color:#F4E8D4">
          <div class="flex justify-between text-sm text-gray-700">
            <span id="price-label">${Number(unit.price_per_night).toLocaleString('es-CL')} × <span id="nights-count">{nights}</span> noche{nights !== 1 ? 's' : ''}</span>
            <span id="subtotal">${total.toLocaleString('es-CL')}</span>
          </div>
          <div class="border-t pt-2 flex justify-between text-sm font-bold" style="border-color:#D9C3A5">
            <span>Total</span>
            <span id="total-price" style="color:#F27C38">${total.toLocaleString('es-CL')}</span>
          </div>
        </div>

        <button type="submit" id="pay-btn"
          class="w-full py-4 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition flex items-center justify-center gap-2"
          style="background-color:#6D4C3D">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
          </svg>
          Pagar con Webpay
        </button>

        <p class="text-xs text-center text-gray-400">
          Pago seguro procesado por Transbank · Webpay Plus
        </p>
      </form>

      <!-- Resumen -->
      <div class="space-y-4">
        <div class="border rounded-2xl overflow-hidden" style="border-color:#e8ddd4">
          <div class="h-36" style="background-color:#F4E8D4;display:flex;align-items:center;justify-content:center;opacity:0.3"><img src="/favicon.png" alt="" style="width:4rem;height:4rem;object-fit:contain" /></div>
          <div class="p-4">
            <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white mb-2 inline-block"
                  style="background-color:#2E593F">
              {unitTypeLabel[unit.type] ?? unit.type}
            </span>
            <h3 class="font-semibold text-gray-900">{unit.name}</h3>
            <p class="text-xs text-gray-400 mt-0.5">{camping?.name} · {camping?.city}</p>
          </div>
        </div>

        <div class="rounded-xl p-4 border text-xs text-gray-500 space-y-1.5" style="border-color:#e8ddd4">
          <p>🔒 Pago 100% seguro con SSL</p>
          <p>📋 Recibirás confirmación por email</p>
          <p>❌ Cancelación gratuita antes del check-in</p>
        </div>
      </div>
    </div>
  </form>
  </main>
</PublicLayout>

<script define:vars={{ unitId, campingId, pricePerNight: Number(unit.price_per_night) }}>
  const form     = document.getElementById('booking-form')
  const ciInput  = document.getElementById('checkin')
  const coInput  = document.getElementById('checkout')
  const nightsEl = document.getElementById('nights-count')
  const totalEl  = document.getElementById('total-price')
  const subEl    = document.getElementById('subtotal')

  const fmt = n => '$' + Number(n).toLocaleString('es-CL')

  function updatePrice() {
    const ci = new Date(ciInput.value)
    const co = new Date(coInput.value)
    if (isNaN(ci) || isNaN(co) || co <= ci) return
    const nights = Math.round((co - ci) / 86400000)
    const total  = pricePerNight * nights
    nightsEl.textContent = nights
    totalEl.textContent  = fmt(total)
    subEl.textContent    = fmt(total)
  }

  ciInput?.addEventListener('change', () => {
    const next = new Date(ciInput.value)
    next.setDate(next.getDate() + 1)
    coInput.min = next.toISOString().split('T')[0]
    updatePrice()
  })
  coInput?.addEventListener('change', updatePrice)

  form?.addEventListener('submit', async e => {
    e.preventDefault()
    const btn = document.getElementById('pay-btn')
    btn.textContent = 'Procesando...'
    btn.disabled = true

    const guests   = document.getElementById('guests').value
    const checkin  = ciInput.value
    const checkout = coInput.value
    const nights   = Math.round((new Date(checkout) - new Date(checkin)) / 86400000)
    const total    = pricePerNight * nights

    const res = await fetch('/api/payments/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ unitId, campingId, checkin, checkout, guests: Number(guests), total }),
    })

    const data = await res.json()

    if (data.url && data.token) {
      // Redirigir a Webpay
      const form = document.createElement('form')
      form.method = 'POST'
      form.action = data.url
      const input = document.createElement('input')
      input.type  = 'hidden'
      input.name  = 'token_ws'
      input.value = data.token
      form.appendChild(input)
      document.body.appendChild(form)
      form.submit()
    } else {
      btn.textContent = 'Error — intenta nuevamente'
      btn.disabled = false
    }
  })
</script>
