---
import TravelerLayout from '../../../layouts/TravelerLayout.astro'
import { supabase } from '../../../lib/supabase'

const { id } = Astro.params
const travelerId = 'demo'

const { data: booking } = await supabase
  .from('bookings')
  .select(`id, check_in, check_out, guests, status, payment_status, total_price, created_at,
           units(name, type, price_per_night),
           campings(id, name, city, slug),
           payments(authorization_code, card_last_digits, status),
           reviews(id, rating, comment)`)
  .eq('id', id!)
  .eq('traveler_id', travelerId)
  .single()

if (!booking) return Astro.redirect('/app/bookings')

const b = booking as any
const nights = Math.round((new Date(b.check_out).getTime() - new Date(b.check_in).getTime()) / 86400000)
const canCancel = b.status === 'pending' || b.status === 'confirmed'
const canReview = b.status === 'completed' && !b.reviews?.length

let reviewError = ''
let reviewSuccess = false

if (Astro.request.method === 'POST') {
  const form    = await Astro.request.formData()
  const action  = form.get('action')

  if (action === 'cancel') {
    await supabase.from('bookings').update({ status: 'cancelled' }).eq('id', id!).eq('traveler_id', travelerId)
    return Astro.redirect(`/app/bookings/${id}`)
  }

  if (action === 'review') {
    const rating  = Number(form.get('rating'))
    const comment = form.get('comment')?.toString() ?? ''
    const { error } = await supabase.from('reviews').insert({
      booking_id: id, traveler_id: travelerId,
      camping_id: b.campings?.id, rating, comment,
    })
    if (error) reviewError = 'Error al guardar la reseña.'
    else reviewSuccess = true
  }
}

const statusColor: Record<string, string> = {
  pending: '#F27C38', confirmed: '#2E593F', cancelled: '#ef4444', completed: '#6b7280',
}
const statusLabel: Record<string, string> = {
  pending: 'Pendiente', confirmed: 'Confirmada', cancelled: 'Cancelada', completed: 'Completada',
}
---

<TravelerLayout title="Detalle de reserva" active="/app/bookings">
  <div class="max-w-xl mx-auto space-y-5">

    <a href="/app/bookings" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Mis reservas
    </a>

    <!-- Estado -->
    <div class="bg-white border rounded-2xl p-6" style="border-color:#e8ddd4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-bold text-gray-900" style="font-family:'Playfair Display',serif">{b.campings?.name}</h2>
        <span class="text-xs font-semibold px-3 py-1.5 rounded-full text-white"
              style={`background-color:${statusColor[b.status]}`}>
          {statusLabel[b.status]}
        </span>
      </div>

      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-gray-500">Parcela</span>
          <span class="font-medium">{b.units?.name}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Check-in</span>
          <span class="font-medium">{new Date(b.check_in).toLocaleDateString('es-CL', { dateStyle: 'long' })}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Check-out</span>
          <span class="font-medium">{new Date(b.check_out).toLocaleDateString('es-CL', { dateStyle: 'long' })}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Noches</span>
          <span class="font-medium">{nights}</span>
        </div>
        <div class="flex justify-between">
          <span class="text-gray-500">Huéspedes</span>
          <span class="font-medium">{b.guests}</span>
        </div>
        <div class="flex justify-between border-t pt-2 mt-2" style="border-color:#e8ddd4">
          <span class="font-semibold">Total</span>
          <span class="font-bold text-base" style="color:#F27C38">${Number(b.total_price).toLocaleString('es-CL')}</span>
        </div>
      </div>
    </div>

    <!-- Pago -->
    {b.payments?.[0]?.authorization_code && (
      <div class="bg-white border rounded-2xl p-5" style="border-color:#e8ddd4">
        <h3 class="text-sm font-semibold text-gray-700 mb-3">Detalle del pago</h3>
        <div class="space-y-1.5 text-xs text-gray-500">
          <div class="flex justify-between">
            <span>Código de autorización</span>
            <span class="font-mono font-semibold text-gray-800">{b.payments[0].authorization_code}</span>
          </div>
          {b.payments[0].card_last_digits && (
            <div class="flex justify-between">
              <span>Tarjeta</span>
              <span class="font-mono">•••• {b.payments[0].card_last_digits}</span>
            </div>
          )}
          <div class="flex justify-between">
            <span>Estado</span>
            <span class="font-semibold text-green-600">Pagado con Webpay</span>
          </div>
        </div>
      </div>
    )}

    <!-- Cancelar -->
    {canCancel && (
      <form method="POST">
        <input type="hidden" name="action" value="cancel" />
        <button type="submit"
          onclick="return confirm('¿Seguro que quieres cancelar esta reserva?')"
          class="w-full py-3 rounded-xl text-sm font-semibold border transition hover:bg-red-50 hover:border-red-200 hover:text-red-600"
          style="border-color:#D9C3A5;color:#6b7280">
          Cancelar reserva
        </button>
      </form>
    )}

    <!-- Reseña -->
    {canReview && !reviewSuccess && (
      <div class="bg-white border rounded-2xl p-6" style="border-color:#e8ddd4">
        <h3 class="font-semibold text-gray-900 mb-4" style="font-family:'Playfair Display',serif">
          ¿Cómo fue tu experiencia?
        </h3>
        {reviewError && (
          <div class="mb-4 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700">{reviewError}</div>
        )}
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="review" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Calificación</label>
            <div class="flex gap-2" id="stars">
              {[1,2,3,4,5].map(n => (
                <button type="button" data-value={n}
                  class="star-btn text-3xl transition hover:scale-110 text-gray-300">★</button>
              ))}
            </div>
            <input type="hidden" name="rating" id="rating-input" value="5" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="comment">Comentario</label>
            <textarea id="comment" name="comment" rows="3"
              placeholder="Cuéntanos qué te pareció el camping..."
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none resize-none placeholder:text-gray-400"
              style="border-color:#D9C3A5"></textarea>
          </div>
          <button type="submit"
            class="w-full py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
            style="background-color:#6D4C3D">
            Publicar reseña
          </button>
        </form>
      </div>
    )}

    {reviewSuccess && (
      <div class="bg-white border rounded-2xl p-5 text-center" style="border-color:#e8ddd4;background-color:#e8f3ec">
        <p class="text-sm font-semibold text-green-700">¡Gracias por tu reseña! 🌿</p>
      </div>
    )}
  </div>
</TravelerLayout>

<script>
  let selected = 5
  const btns   = document.querySelectorAll('.star-btn')
  const input  = document.getElementById('rating-input') as HTMLInputElement

  const paint = (val: number) => {
    btns.forEach(b => {
      const v = Number((b as HTMLElement).dataset.value)
      b.classList.toggle('text-yellow-400', v <= val)
      b.classList.toggle('text-gray-300', v > val)
    })
  }

  paint(selected)

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      selected = Number((btn as HTMLElement).dataset.value)
      input.value = String(selected)
      paint(selected)
    })
    btn.addEventListener('mouseenter', () => paint(Number((btn as HTMLElement).dataset.value)))
    btn.addEventListener('mouseleave', () => paint(selected))
  })
</script>
