---
import TravelerLayout from '../../../layouts/TravelerLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../../lib/supabase'

const { user } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

const { data: bookings } = await supabaseAdmin
  .from('bookings')
  .select('id, check_in, check_out, guests, status, total_price, created_at, units(name), campings(name, city, camping_images(url, is_cover))')
  .eq('traveler_id', user.id)
  .order('created_at', { ascending: false })

const statusColor: Record<string, string> = {
  pending: '#F27C38', confirmed: '#2E593F', cancelled: '#ef4444', completed: '#6b7280',
}
const statusLabel: Record<string, string> = {
  pending: 'Pendiente', confirmed: 'Confirmada', cancelled: 'Cancelada', completed: 'Completada',
}
---

<TravelerLayout title="Mis Reservas" active="/app/bookings">
  {!(bookings ?? []).length ? (
    <div class="max-w-md mx-auto text-center py-16">
      <p class="text-6xl mb-4">📋</p>
      <h2 class="text-xl font-bold mb-2 text-gray-900" style="font-family:'Playfair Display',serif">Sin reservas aún</h2>
      <p class="text-gray-500 text-sm mb-6">Cuando reserves un camping aparecerá aquí.</p>
      <a href="/search" class="inline-block px-6 py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90" style="background-color:#6D4C3D">
        Buscar campings
      </a>
    </div>
  ) : (
    <div class="space-y-3">
      {(bookings ?? []).map((b: any) => {
        const cover = b.campings?.camping_images?.find((i: any) => i.is_cover) ?? b.campings?.camping_images?.[0]
        return (
          <a href={`/app/bookings/${b.id}`}
             class="group flex gap-4 bg-white border rounded-2xl p-4 hover:shadow-md transition-shadow"
             style="border-color:#e8ddd4">
            <div class="w-20 h-20 rounded-xl overflow-hidden shrink-0" style="background-color:#F4E8D4">
              {cover
                ? <img src={cover.url} alt={b.campings?.name} class="w-full h-full object-cover" />
                : <div class="w-full h-full flex items-center justify-center opacity-30"><img src="/favicon.png" alt="" class="w-8 h-8 object-contain" /></div>
              }
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-xs text-gray-400">{b.campings?.city}</p>
                  <h3 class="font-semibold text-sm text-gray-900 group-hover:text-[#6D4C3D] transition truncate">{b.campings?.name}</h3>
                  <p class="text-xs text-gray-500 mt-0.5">{b.units?.name}</p>
                </div>
                <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                      style={`background-color:${statusColor[b.status]}`}>
                  {statusLabel[b.status]}
                </span>
              </div>
              <div class="flex items-center justify-between mt-2">
                <p class="text-xs text-gray-400">
                  {new Date(b.check_in).toLocaleDateString('es-CL')} → {new Date(b.check_out).toLocaleDateString('es-CL')} · {b.guests} pers.
                </p>
                <p class="text-sm font-bold" style="color:#F27C38">${Number(b.total_price).toLocaleString('es-CL')}</p>
              </div>
            </div>
          </a>
        )
      })}
    </div>
  )}
</TravelerLayout>
