---
import PublicLayout from '../layouts/PublicLayout.astro'
import Navbar from '../components/layout/Navbar.astro'
---

<PublicLayout title="Página no encontrada">
  <Navbar />
  <main class="pt-32 pb-20 max-w-lg mx-auto px-4 text-center">
    <p class="text-8xl mb-6">🏕️</p>
    <h1 class="text-4xl font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif">
      Página no encontrada
    </h1>
    <p class="text-gray-500 mb-8">
      Esta ruta no existe o el camping que buscas fue dado de baja.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href="/"
         class="px-6 py-3 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
         style="border-color:#D9C3A5;color:#6D4C3D">
        Ir al inicio
      </a>
      <a href="/search"
         class="px-6 py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
         style="background-color:#6D4C3D">
        Buscar campings
      </a>
    </div>
  </main>
</PublicLayout>
