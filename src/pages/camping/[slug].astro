---
import PublicLayout from '../../layouts/PublicLayout.astro'
import Navbar from '../../components/layout/Navbar.astro'
import Footer from '../../components/layout/Footer.astro'
import { supabase, getSessionUser } from '../../lib/supabase'

const { slug } = Astro.params
const { user, profile } = await getSessionUser(Astro.cookies)

const { data: camping } = await supabase
  .from('campings')
  .select(`
    id, name, slug, description, address, city, country, lat, lng, rules, owner_id,
    camping_images(id, url, is_cover, "order"),
    units(id, name, type, capacity, price_per_night, amenities, description, status),
    reviews(id, rating, comment, created_at, profiles!traveler_id(full_name))
  `)
  .eq('slug', slug)
  .eq('status', 'active')
  .single()

if (!camping) return Astro.redirect('/404')

const images   = [...(camping.camping_images ?? [])].sort((a: any, b: any) => a.order - b.order)
const cover    = images.find((i: any) => i.is_cover) ?? images[0]
const units    = (camping.units ?? []).filter((u: any) => u.status === 'active')
const reviews  = camping.reviews ?? []
const avgRating = reviews.length
  ? (reviews.reduce((s: number, r: any) => s + r.rating, 0) / reviews.length).toFixed(1)
  : null

const unitTypeLabel: Record<string, string> = {
  tent: 'Sitio', cabin: 'Cabaña', glamping: 'Glamping', camper: 'Camper', other: 'Otro',
}
---

<PublicLayout
  title={camping.name}
  description={camping.description ?? `Camping ${camping.name} en ${camping.city}, ${camping.country}`}
  image={cover?.url}
>
  <Navbar />

  <main class="pt-16 max-w-7xl mx-auto px-4 sm:px-6 pb-20">

    <!-- Galería -->
    <div class="my-6 relative">
      {images.length === 0 ? (
        <div class="rounded-2xl h-64 sm:h-96 flex items-center justify-center opacity-30" style="background-color:#F4E8D4">
          <img src="/favicon.png" alt="" class="w-20 h-20 object-contain" />
        </div>
      ) : (
        <div class="grid grid-cols-4 grid-rows-2 gap-2 rounded-2xl overflow-hidden h-64 sm:h-96">
          <!-- Foto principal -->
          <div class="col-span-2 row-span-2 overflow-hidden">
            <img src={images[0]?.url} alt={camping.name}
                 class="gallery-thumb w-full h-full object-cover hover:scale-105 transition-transform duration-500 cursor-pointer"
                 data-index="0" />
          </div>
          <!-- Fotos secundarias -->
          {images.slice(1, 5).map((img: any, i: number) => (
            <div class="overflow-hidden relative">
              <img src={img.url} alt={`${camping.name} foto ${i + 2}`}
                   class="gallery-thumb w-full h-full object-cover hover:scale-105 transition-transform duration-500 cursor-pointer"
                   data-index={i + 1} />
              <!-- Botón "Ver todas" sobre la última celda visible -->
              {i === 3 && images.length > 5 && (
                <button id="btn-ver-todas"
                  class="absolute inset-0 flex items-end justify-end p-3 cursor-pointer"
                  style="background:rgba(0,0,0,0.35)">
                  <span class="bg-white text-gray-900 text-xs font-semibold px-3 py-1.5 rounded-lg shadow">
                    Ver todas ({images.length})
                  </span>
                </button>
              )}
            </div>
          ))}
          {images.length < 5 && Array.from({ length: 4 - Math.min(images.length - 1, 4) }).map(() => (
            <div style="background-color:#F4E8D4"></div>
          ))}
        </div>
      )}
      <!-- Botón flotante "Ver todas" cuando hay > 1 foto y ≤ 5 (no se solapó con el overlay) -->
      {images.length > 1 && images.length <= 5 && (
        <button id="btn-ver-todas"
          class="absolute bottom-3 right-3 bg-white text-gray-900 text-xs font-semibold px-3 py-1.5 rounded-lg shadow hover:shadow-md transition">
          Ver todas ({images.length})
        </button>
      )}
    </div>

    <!-- Modal galería -->
    <div id="gallery-modal"
         class="fixed inset-0 z-50 hidden items-center justify-center"
         style="background:rgba(0,0,0,0.92)">

      <!-- Cerrar -->
      <button id="modal-close"
              class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full text-white hover:bg-white/20 transition"
              aria-label="Cerrar">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- Contador -->
      <div id="modal-counter" class="absolute top-4 left-1/2 -translate-x-1/2 text-white/70 text-sm font-medium"></div>

      <!-- Imagen -->
      <div class="w-full h-full flex items-center justify-center px-14 sm:px-20 py-16">
        <img id="modal-img" src="" alt=""
             class="max-w-full max-h-full object-contain rounded-xl select-none"
             draggable="false" />
      </div>

      <!-- Prev -->
      <button id="modal-prev"
              class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center rounded-full text-white hover:bg-white/20 transition"
              aria-label="Anterior">
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <!-- Next -->
      <button id="modal-next"
              class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 w-11 h-11 flex items-center justify-center rounded-full text-white hover:bg-white/20 transition"
              aria-label="Siguiente">
        <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </button>

      <!-- Thumbnails strip (solo desktop) -->
      <div id="modal-strip"
           class="absolute bottom-4 left-1/2 -translate-x-1/2 hidden sm:flex gap-2 max-w-lg overflow-x-auto px-2 pb-1">
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-10">

      <!-- Contenido principal -->
      <div class="lg:col-span-2 space-y-8">

        <!-- Header -->
        <div>
          <p class="text-sm text-gray-400 mb-1">{camping.city}{camping.city ? ', ' : ''}{camping.country}</p>
          <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif">
            {camping.name}
          </h1>
          {avgRating && (
            <div class="flex items-center gap-2">
              <span class="text-sm font-semibold">⭐ {avgRating}</span>
              <span class="text-sm text-gray-400">· {reviews.length} reseña{reviews.length !== 1 ? 's' : ''}</span>
            </div>
          )}
        </div>

        <!-- Descripción -->
        {camping.description && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif">
              Sobre este camping
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm">{camping.description}</p>
          </div>
        )}

        <!-- Unidades disponibles -->
        <div>
          <h2 class="text-lg font-bold text-gray-900 mb-4" id="unidades" style="font-family:'Playfair Display',serif">
            Alojamientos disponibles
          </h2>
          {units.length === 0 ? (
            <p class="text-gray-400 text-sm">No hay unidades disponibles por el momento.</p>
          ) : (
            <div class="space-y-4">
              {units.map((u: any) => (
                <div class="border rounded-2xl p-5 hover:shadow-md transition-shadow" style="border-color:#e8ddd4">
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <div>
                      <span class="inline-block text-xs font-semibold px-2 py-0.5 rounded-full mb-2 text-white"
                            style="background-color:#2E593F">
                        {unitTypeLabel[u.type] ?? u.type}
                      </span>
                      <h3 class="font-semibold text-gray-900">{u.name}</h3>
                      <p class="text-xs text-gray-400 mt-0.5">{u.capacity} persona{u.capacity !== 1 ? 's' : ''} máximo</p>
                    </div>
                    <div class="text-right shrink-0">
                      <p class="text-xl font-bold" style="color:#F27C38">
                        ${Number(u.price_per_night).toLocaleString('es-CL')}
                      </p>
                      <p class="text-xs text-gray-400">por noche</p>
                    </div>
                  </div>
                  {u.description && (
                    <p class="text-xs text-gray-500 mb-3">{u.description}</p>
                  )}
                  {Array.isArray(u.amenities) && u.amenities.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {u.amenities.map((a: string) => (
                        <span class="text-xs px-2 py-1 rounded-lg font-medium" style="background-color:#F4E8D4;color:#6D4C3D">
                          {a}
                        </span>
                      ))}
                    </div>
                  )}
                  <a href={`/app/booking/new?unit=${u.id}&camping=${camping.id}`}
                     class="block w-full text-center py-2.5 rounded-xl text-sm font-semibold text-white hover:opacity-90 transition"
                     style="background-color:#6D4C3D">
                    Reservar
                  </a>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Mobile contact button -->
        <div class="lg:hidden">
          {profile?.role === 'traveler' ? (
            <form method="POST" action="/api/conversations/new">
              <input type="hidden" name="campingId" value={camping.id} />
              <input type="hidden" name="hostId" value={(camping as any).owner_id} />
              <button type="submit"
                class="w-full py-3 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
                style="border-color:#D9C3A5;color:#6D4C3D">
                Contactar al host
              </button>
            </form>
          ) : !user ? (
            <a href={`/auth/login?redirect=/camping/${slug}`}
               class="block w-full py-3 rounded-xl text-sm font-semibold border transition hover:bg-gray-50 text-center"
               style="border-color:#D9C3A5;color:#6D4C3D">
              Iniciar sesión para contactar
            </a>
          ) : null}
        </div>

        <!-- Reglas -->
        {camping.rules && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-3" style="font-family:'Playfair Display',serif">
              Reglas del camping
            </h2>
            <p class="text-sm text-gray-600 leading-relaxed whitespace-pre-line">{camping.rules}</p>
          </div>
        )}

        <!-- Reseñas -->
        {reviews.length > 0 && (
          <div>
            <h2 class="text-lg font-bold text-gray-900 mb-4" style="font-family:'Playfair Display',serif">
              Reseñas · ⭐ {avgRating}
            </h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {reviews.map((r: any) => (
                <div class="rounded-2xl p-4 border" style="border-color:#e8ddd4;background-color:#faf8f5">
                  <div class="flex items-center justify-between mb-2">
                    <p class="text-sm font-semibold text-gray-800">{(r as any).profiles?.full_name ?? 'Viajero'}</p>
                    <span class="text-xs text-gray-400">
                      {'⭐'.repeat(r.rating)}
                    </span>
                  </div>
                  {r.comment && <p class="text-xs text-gray-600 leading-relaxed">{r.comment}</p>}
                  <p class="text-xs text-gray-300 mt-2">
                    {new Date(r.created_at).toLocaleDateString('es-CL', { month: 'long', year: 'numeric' })}
                  </p>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sticky sidebar -->
      <div class="hidden lg:block">
        <div class="sticky top-24 space-y-4">
          <!-- Mapa -->
          {camping.lat && camping.lng && (
            <div class="border rounded-2xl overflow-hidden" style="border-color:#e8ddd4">
              <div id="detail-map" class="h-48 w-full"></div>
              <div class="p-4">
                <p class="text-xs text-gray-500">
                  <svg class="w-3.5 h-3.5 inline mr-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {camping.address ?? ''}{camping.address && camping.city ? ', ' : ''}{camping.city}
                </p>
              </div>
            </div>
          )}

          <!-- Precio desde -->
          {units.length > 0 && (
            <div class="border rounded-2xl p-5 text-center" style="border-color:#e8ddd4">
              <p class="text-xs text-gray-400 mb-1">Desde</p>
              <p class="text-3xl font-bold mb-1" style="color:#F27C38">
                ${Math.min(...units.map((u: any) => Number(u.price_per_night))).toLocaleString('es-CL')}
              </p>
              <p class="text-xs text-gray-400 mb-4">por noche</p>
              <a href="#unidades"
                 class="block w-full py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
                 style="background-color:#6D4C3D">
                Ver alojamientos disponibles
              </a>
              {/* Contact host button */}
              {profile?.role === 'traveler' ? (
                <form method="POST" action="/api/conversations/new">
                  <input type="hidden" name="campingId" value={camping.id} />
                  <input type="hidden" name="hostId" value={(camping as any).owner_id} />
                  <button type="submit"
                    class="mt-2 block w-full py-3 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
                    style="border-color:#D9C3A5;color:#6D4C3D">
                    Contactar al host
                  </button>
                </form>
              ) : !user ? (
                <a href={`/auth/login?redirect=/camping/${slug}`}
                   class="mt-2 block w-full py-3 rounded-xl text-sm font-semibold border transition hover:bg-gray-50 text-center"
                   style="border-color:#D9C3A5;color:#6D4C3D">
                  Iniciar sesión para contactar
                </a>
              ) : null}
            </div>
          )}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</PublicLayout>

<script define:vars={{ galleryImages: images.map((i: any) => i.url) }}>
  const modal   = document.getElementById('gallery-modal')
  const modalImg = document.getElementById('modal-img')
  const counter  = document.getElementById('modal-counter')
  const strip    = document.getElementById('modal-strip')
  const btnClose = document.getElementById('modal-close')
  const btnPrev  = document.getElementById('modal-prev')
  const btnNext  = document.getElementById('modal-next')
  const btnVerTodas = document.getElementById('btn-ver-todas')

  let current = 0
  const total = galleryImages.length

  function open(index) {
    current = ((index % total) + total) % total
    render()
    modal.classList.remove('hidden')
    modal.classList.add('flex')
    document.body.style.overflow = 'hidden'
  }

  function close() {
    modal.classList.add('hidden')
    modal.classList.remove('flex')
    document.body.style.overflow = ''
  }

  function render() {
    modalImg.src = galleryImages[current]
    counter.textContent = `${current + 1} / ${total}`
    // Thumbnails strip
    strip.innerHTML = ''
    galleryImages.forEach((url, i) => {
      const th = document.createElement('img')
      th.src = url
      th.alt = ''
      th.className = 'h-14 w-20 object-cover rounded-lg cursor-pointer flex-shrink-0 transition ring-2 ' +
        (i === current ? 'ring-white opacity-100' : 'ring-transparent opacity-50 hover:opacity-80')
      th.addEventListener('click', () => open(i))
      strip.appendChild(th)
    })
    // Scroll activo al centro
    const active = strip.children[current]
    if (active) active.scrollIntoView({ inline: 'center', behavior: 'smooth', block: 'nearest' })
    // Ocultar flechas si solo hay 1
    btnPrev.style.display = total <= 1 ? 'none' : ''
    btnNext.style.display = total <= 1 ? 'none' : ''
  }

  // Abrir desde thumbs del grid
  document.querySelectorAll('.gallery-thumb').forEach(img => {
    img.addEventListener('click', () => open(Number(img.dataset.index)))
  })

  // Botón "Ver todas"
  if (btnVerTodas) btnVerTodas.addEventListener('click', () => open(0))

  btnClose?.addEventListener('click', close)
  btnPrev?.addEventListener('click', () => open(current - 1))
  btnNext?.addEventListener('click', () => open(current + 1))

  // Teclado
  document.addEventListener('keydown', e => {
    if (modal.classList.contains('hidden')) return
    if (e.key === 'Escape')      close()
    if (e.key === 'ArrowLeft')   open(current - 1)
    if (e.key === 'ArrowRight')  open(current + 1)
  })

  // Cerrar al click en backdrop
  modal.addEventListener('click', e => { if (e.target === modal) close() })

  // Swipe touch para mobile
  let touchStartX = 0
  modal.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX }, { passive: true })
  modal.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX
    if (Math.abs(dx) > 50) dx < 0 ? open(current + 1) : open(current - 1)
  }, { passive: true })
</script>

{camping.lat && camping.lng && (
  <>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script define:vars={{ lat: camping.lat, lng: camping.lng, name: camping.name }}>
      const map = L.map('detail-map', { zoomControl: false, scrollWheelZoom: false })
        .setView([lat, lng], 13)
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
      }).addTo(map)
      L.circleMarker([lat, lng], {
        radius: 10, fillColor: '#6D4C3D', color: 'white',
        weight: 3, fillOpacity: 1
      }).addTo(map)
    </script>
  </>
)}
