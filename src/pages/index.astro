---
import PublicLayout from '../layouts/PublicLayout.astro'
import Navbar from '../components/layout/Navbar.astro'
import Footer from '../components/layout/Footer.astro'
import { supabase } from '../lib/supabase'

const { data: featured } = await supabase
  .from('campings')
  .select(`id, name, slug, city, country, camping_images(url, is_cover), reviews(rating)`)
  .eq('status', 'active')
  .limit(6)

const campings = (featured ?? []).map((c: any) => {
  const cover   = c.camping_images?.find((i: any) => i.is_cover) ?? c.camping_images?.[0]
  const ratings: number[] = c.reviews?.map((r: any) => r.rating) ?? []
  const avg     = ratings.length ? (ratings.reduce((a: number, b: number) => a + b, 0) / ratings.length).toFixed(1) : null
  return { ...c, coverUrl: cover?.url ?? null, rating: avg, reviewCount: ratings.length }
})

const unitTypes = [
  { value: 'tent',     label: 'Carpas',   emoji: '⛺' },
  { value: 'cabin',    label: 'Cabañas',  emoji: '🏠' },
  { value: 'glamping', label: 'Glamping', emoji: '✨' },
  { value: 'camper',   label: 'Camper',   emoji: '🚐' },
]
---

<PublicLayout>
  <Navbar transparent={true} />

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <!-- Foto de fondo -->
    <div class="absolute inset-0 bg-cover bg-center bg-no-repeat"
         style="background-image:url('/hero.jpg')"></div>
    <!-- Overlay degradé con translucidez -->
    <div class="absolute inset-0"
         style="background:linear-gradient(135deg,rgba(46,89,63,0.82) 0%,rgba(61,110,80,0.70) 40%,rgba(109,76,61,0.80) 100%)"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto pt-16">
      <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold mb-6 text-white/80"
            style="background-color:rgba(255,255,255,0.15)">
        🏕️ El marketplace de campings en Chile
      </span>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-5 leading-tight"
          style="font-family:'Playfair Display',serif">
        Tu próxima aventura<br />
        <span style="color:#F27C38">en la naturaleza</span>
      </h1>

      <p class="text-white/75 text-lg sm:text-xl mb-10 max-w-2xl mx-auto">
        Descubre campings únicos, cabañas y glamping en los paisajes más increíbles de Chile.
      </p>

      <form action="/search" method="GET"
        class="bg-white rounded-2xl p-3 shadow-2xl flex flex-col sm:flex-row gap-3 max-w-2xl mx-auto">
        <div class="flex-1 flex items-center gap-3 px-3">
          <svg class="w-5 h-5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          </svg>
          <input name="q" type="text" placeholder="¿A dónde quieres ir?"
            class="w-full text-sm outline-none text-gray-800 placeholder:text-gray-400 py-2" />
        </div>
        <div class="hidden sm:block w-px my-2" style="background-color:#e8ddd4"></div>
        <div class="flex-1 flex items-center gap-3 px-3">
          <svg class="w-5 h-5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <input name="checkin" type="date"
            class="w-full text-sm outline-none text-gray-800 py-2" />
        </div>
        <button type="submit"
          class="px-6 py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition shrink-0"
          style="background-color:#F27C38">
          Buscar
        </button>
      </form>
    </div>

    <div class="absolute bottom-0 inset-x-0">
      <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 80L1440 80L1440 30C1200 70 960 10 720 40C480 70 240 10 0 30L0 80Z" fill="white"/>
      </svg>
    </div>
  </section>

  <!-- TIPOS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6" style="font-family:'Playfair Display',serif">
      Explora por tipo
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {unitTypes.map(t => (
        <a href={`/search?type=${t.value}`}
           class="group flex flex-col items-center gap-3 p-6 rounded-2xl border-2 transition hover:shadow-md"
           style="border-color:#e8ddd4;background-color:#faf8f5">
          <span class="text-4xl">{t.emoji}</span>
          <span class="text-sm font-semibold text-gray-700 group-hover:text-[#6D4C3D] transition">{t.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- DESTACADOS -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 pb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900" style="font-family:'Playfair Display',serif">
        Campings destacados
      </h2>
      <a href="/search" class="text-sm font-medium hover:underline" style="color:#6D4C3D">Ver todos →</a>
    </div>

    {campings.length === 0 ? (
      <div class="text-center py-20 text-gray-400">
        <p class="text-5xl mb-4">⛺</p>
        <p class="text-sm">Pronto habrá campings disponibles.</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {campings.map((c: any) => (
          <a href={`/camping/${c.slug}`}
             class="group block rounded-2xl overflow-hidden border hover:shadow-lg transition-shadow"
             style="border-color:#e8ddd4">
            <div class="relative h-52 overflow-hidden" style="background-color:#F4E8D4">
              {c.coverUrl ? (
                <img src={c.coverUrl} alt={c.name}
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-6xl opacity-40">⛺</div>
              )}
              {c.rating && (
                <div class="absolute top-3 right-3 flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold text-white"
                     style="background-color:rgba(0,0,0,0.5)">
                  ⭐ {c.rating}
                </div>
              )}
            </div>
            <div class="p-4">
              <p class="text-xs text-gray-400 mb-1">{c.city}{c.city ? ', ' : ''}{c.country}</p>
              <h3 class="font-semibold text-gray-900 group-hover:text-[#6D4C3D] transition">{c.name}</h3>
              {c.reviewCount > 0 && (
                <p class="text-xs text-gray-400 mt-1">{c.reviewCount} reseña{c.reviewCount !== 1 ? 's' : ''}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <!-- CTA HOST -->
  <section class="mx-4 sm:mx-6 lg:mx-auto max-w-7xl mb-16">
    <div class="rounded-3xl overflow-hidden relative px-8 py-14 text-center"
         style="background:linear-gradient(135deg,#6D4C3D,#8b6355)">
      <div class="absolute inset-0 opacity-10"
           style="background-image:radial-gradient(circle at 1px 1px, white 1px, transparent 0);background-size:32px 32px"></div>
      <div class="relative z-10 max-w-xl mx-auto">
        <h2 class="text-3xl font-bold text-white mb-3" style="font-family:'Playfair Display',serif">
          ¿Tienes un camping?
        </h2>
        <p class="text-white/70 mb-7 text-base">
          Publica tus parcelas y cabañas, gestiona reservas y recibe pagos. Gratis para empezar.
        </p>
        <a href="/auth/register"
           class="inline-block px-7 py-3.5 rounded-xl text-sm font-semibold hover:opacity-90 transition"
           style="background-color:#F27C38;color:white">
          Publicar mi camping
        </a>
      </div>
    </div>
  </section>

  <Footer />
</PublicLayout>
