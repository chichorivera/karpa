---
import AuthLayout from '../../layouts/AuthLayout.astro'
import { supabase } from '../../lib/supabase'

let error = ''
let success = false

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const full_name = form.get('full_name')?.toString() ?? ''
  const email     = form.get('email')?.toString() ?? ''
  const password  = form.get('password')?.toString() ?? ''
  const role      = form.get('role')?.toString() === 'host' ? 'host' : 'traveler'

  const { data, error: authError } = await supabase.auth.signUp({
    email,
    password,
    options: { data: { full_name } },
  })

  if (authError) {
    error = authError.message.includes('already registered')
      ? 'Este email ya está registrado.'
      : 'Error al crear la cuenta. Intenta nuevamente.'
  } else if (data.user) {
    // Asignar rol seleccionado
    await supabase
      .from('profiles')
      .update({ role, full_name })
      .eq('id', data.user.id)

    success = true
  }
}
---

<AuthLayout title="Crear cuenta">
  <div>
    <h1 class="text-3xl font-bold mb-2" style="font-family:'Playfair Display',serif;color:#1a1a1a">
      Crea tu cuenta
    </h1>
    <p class="text-gray-500 mb-8 text-sm">Únete a la comunidad de campings en Chile</p>

    {error && (
      <div class="mb-6 px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100">
        {error}
      </div>
    )}

    {success ? (
      <div class="text-center py-8">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4"
             style="background-color:#F4E8D4">
          <svg class="w-8 h-8" style="color:#2E593F" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-2" style="font-family:'Playfair Display',serif">¡Cuenta creada!</h2>
        <p class="text-gray-500 text-sm mb-6">
          Te enviamos un email de confirmación. Revisa tu bandeja de entrada.
        </p>
        <a href="/auth/login"
           class="inline-block px-6 py-3 rounded-xl text-white text-sm font-semibold"
           style="background-color:#6D4C3D">
          Ir al login
        </a>
      </div>
    ) : (
      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="full_name">
            Nombre completo
          </label>
          <input
            id="full_name" name="full_name" type="text" required autocomplete="name"
            placeholder="Juan Pérez"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm outline-none transition
                   focus:border-[#6D4C3D] focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">
            Correo electrónico
          </label>
          <input
            id="email" name="email" type="email" required autocomplete="email"
            placeholder="tu@email.com"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm outline-none transition
                   focus:border-[#6D4C3D] focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="password">
            Contraseña
          </label>
          <input
            id="password" name="password" type="password" required minlength="8"
            placeholder="Mínimo 8 caracteres"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm outline-none transition
                   focus:border-[#6D4C3D] focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          />
        </div>

        <!-- Selección de rol -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-3">¿Cómo usarás Karpa?</label>
          <div class="grid grid-cols-2 gap-3">
            <label class="role-card cursor-pointer">
              <input type="radio" name="role" value="traveler" class="sr-only" checked />
              <div class="flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 border-gray-200
                          transition hover:border-[#6D4C3D] peer-checked:border-[#6D4C3D]
                          role-option text-center">
                <img src="/icon-viajero.png" alt="Viajero" class="w-10 h-10 object-contain" />
                <span class="text-sm font-semibold text-gray-800">Viajero</span>
                <span class="text-xs text-gray-400">Quiero reservar campings</span>
              </div>
            </label>
            <label class="role-card cursor-pointer">
              <input type="radio" name="role" value="host" class="sr-only" />
              <div class="flex flex-col items-center gap-2 px-4 py-4 rounded-xl border-2 border-gray-200
                          transition hover:border-[#6D4C3D]
                          role-option text-center">
                <img src="/icon-dueno-cabana.png" alt="Dueño de camping" class="w-10 h-10 object-contain" />
                <span class="text-sm font-semibold text-gray-800">Dueño de camping</span>
                <span class="text-xs text-gray-400">Quiero publicar mi camping</span>
              </div>
            </label>
          </div>
        </div>

        <button
          type="submit"
          class="w-full py-3.5 rounded-xl text-white text-sm font-semibold transition
                 hover:opacity-90 active:scale-[0.99]"
          style="background-color:#6D4C3D"
        >
          Crear cuenta gratis
        </button>

        <p class="text-center text-xs text-gray-400">
          Al registrarte aceptas nuestros
          <a href="/terminos" class="underline">Términos</a> y
          <a href="/privacidad" class="underline">Política de privacidad</a>
        </p>
      </form>
    )}

    <p class="mt-8 text-center text-sm text-gray-500">
      ¿Ya tienes cuenta?{' '}
      <a href="/auth/login" class="font-semibold hover:underline" style="color:#6D4C3D">
        Iniciar sesión
      </a>
    </p>
  </div>

  <script>
    // Highlight de tarjeta de rol seleccionada
    document.querySelectorAll('.role-card').forEach(card => {
      const input = card.querySelector('input[type="radio"]') as HTMLInputElement
      const box   = card.querySelector('.role-option') as HTMLElement

      const update = () => {
        document.querySelectorAll('.role-option').forEach(b =>
          b.classList.remove('border-[#6D4C3D]', 'bg-[#F4E8D4]')
        )
        if (input.checked) {
          box.classList.add('border-[#6D4C3D]', 'bg-[#F4E8D4]')
        }
      }

      input.addEventListener('change', update)
      if (input.checked) update()
    })
  </script>
</AuthLayout>
