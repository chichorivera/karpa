---
import AuthLayout from '../../layouts/AuthLayout.astro'
import { createSupabaseServerClient } from '../../lib/supabase'

let error = ''
const next = Astro.url.searchParams.get('next') ?? ''

if (Astro.request.method === 'POST') {
  const form     = await Astro.request.formData()
  const email    = form.get('email')?.toString() ?? ''
  const password = form.get('password')?.toString() ?? ''

  const client = createSupabaseServerClient(Astro.cookies)
  const { data, error: authError } = await client.auth.signInWithPassword({ email, password })

  if (authError) {
    error = 'Email o contraseña incorrectos.'
  } else if (data.user) {
    const { data: profile } = await client
      .from('profiles').select('role').eq('id', data.user.id).single()

    const redirectMap: Record<string, string> = {
      admin:    '/admin/dashboard',
      host:     '/host/dashboard',
      traveler: '/app/dashboard',
    }
    const dest = next || (redirectMap[profile?.role ?? 'traveler'] ?? '/')
    return Astro.redirect(dest)
  }
}
---

<AuthLayout title="Iniciar sesión">
  <div>
    <h1 class="text-3xl font-bold mb-2" style="font-family:'Playfair Display',serif;color:#1a1a1a">
      Bienvenido de vuelta
    </h1>
    <p class="text-gray-500 mb-8 text-sm">Ingresa tus datos para continuar</p>

    {error && (
      <div class="mb-6 px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">Correo electrónico</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="tu@email.com"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          style="border-color:#D9C3A5" />
      </div>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <label class="block text-sm font-medium text-gray-700" for="password">Contraseña</label>
          <a href="/auth/reset-password" class="text-xs font-medium hover:underline" style="color:#F27C38">
            ¿Olvidaste tu contraseña?
          </a>
        </div>
        <input id="password" name="password" type="password" required autocomplete="current-password" placeholder="••••••••"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          style="border-color:#D9C3A5" />
      </div>
      <button type="submit"
        class="w-full py-3.5 rounded-xl text-white text-sm font-semibold transition hover:opacity-90 active:scale-[0.99]"
        style="background-color:#6D4C3D">
        Iniciar sesión
      </button>
    </form>

    <p class="mt-8 text-center text-sm text-gray-500">
      ¿No tienes cuenta?{' '}
      <a href="/auth/register" class="font-semibold hover:underline" style="color:#6D4C3D">Regístrate gratis</a>
    </p>
  </div>
</AuthLayout>
