---
import AuthLayout from '../../layouts/AuthLayout.astro'
import { supabase } from '../../lib/supabase'

let error = ''
let success = false

if (Astro.request.method === 'POST') {
  const form  = await Astro.request.formData()
  const email = form.get('email')?.toString() ?? ''

  const { error: resetError } = await supabase.auth.resetPasswordForEmail(email, {
    redirectTo: `${import.meta.env.PUBLIC_BASE_URL}/auth/update-password`,
  })

  if (resetError) {
    error = 'No pudimos procesar la solicitud. Intenta nuevamente.'
  } else {
    success = true
  }
}
---

<AuthLayout title="Recuperar contraseña">
  <div>
    <a href="/auth/login"
       class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-8 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver al login
    </a>

    <h1 class="text-3xl font-bold mb-2" style="font-family:'Playfair Display',serif;color:#1a1a1a">
      Recupera tu contraseña
    </h1>
    <p class="text-gray-500 mb-8 text-sm">
      Te enviamos un enlace para restablecer tu contraseña.
    </p>

    {error && (
      <div class="mb-6 px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100">
        {error}
      </div>
    )}

    {success ? (
      <div class="text-center py-8">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4"
             style="background-color:#F4E8D4">
          <svg class="w-8 h-8" style="color:#2E593F" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold mb-2" style="font-family:'Playfair Display',serif">Revisa tu email</h2>
        <p class="text-gray-500 text-sm">
          Si el correo existe en nuestra base de datos, recibirás un enlace en los próximos minutos.
        </p>
      </div>
    ) : (
      <form method="POST" class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="email">
            Correo electrónico
          </label>
          <input
            id="email" name="email" type="email" required autocomplete="email"
            placeholder="tu@email.com"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm outline-none transition
                   focus:border-[#6D4C3D] focus:ring-2 focus:ring-[#6D4C3D]/10 placeholder:text-gray-400"
          />
        </div>

        <button
          type="submit"
          class="w-full py-3.5 rounded-xl text-white text-sm font-semibold transition
                 hover:opacity-90 active:scale-[0.99]"
          style="background-color:#6D4C3D"
        >
          Enviar enlace de recuperación
        </button>
      </form>
    )}
  </div>
</AuthLayout>
