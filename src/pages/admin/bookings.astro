---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { supabaseAdmin } from '../../lib/supabase'

const { data: bookings } = await supabaseAdmin
  .from('bookings')
  .select(`id, check_in, check_out, guests, total_price, status, payment_status, created_at,
           units(name), campings(name),
           profiles!traveler_id(full_name)`)
  .order('created_at', { ascending: false })
  .limit(100)

const statusColor: Record<string, string> = {
  pending: '#F27C38', confirmed: '#2E593F', cancelled: '#ef4444', completed: '#6b7280',
}
const statusLabel: Record<string, string> = {
  pending: 'Pendiente', confirmed: 'Confirmada', cancelled: 'Cancelada', completed: 'Completada',
}
---

<AdminLayout title="Reservas" active="/admin/bookings">
  <div class="bg-white rounded-2xl border overflow-x-auto" style="border-color:#e8ddd4">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left" style="border-color:#e8ddd4;background-color:#faf8f5">
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Viajero</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Camping</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 hidden md:table-cell">Fechas</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Total</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Estado</th>
        </tr>
      </thead>
      <tbody class="divide-y" style="divide-color:#f0e8e0">
        {(bookings ?? []).map((b: any) => (
          <tr>
            <td class="px-5 py-3.5 font-medium text-gray-900">{b.profiles?.full_name ?? '—'}</td>
            <td class="px-5 py-3.5">
              <p class="text-gray-900">{b.campings?.name}</p>
              <p class="text-xs text-gray-400">{b.units?.name}</p>
            </td>
            <td class="px-5 py-3.5 text-gray-500 text-xs hidden md:table-cell">
              {new Date(b.check_in).toLocaleDateString('es-CL')} → {new Date(b.check_out).toLocaleDateString('es-CL')}
            </td>
            <td class="px-5 py-3.5 font-bold" style="color:#F27C38">
              ${Number(b.total_price).toLocaleString('es-CL')}
            </td>
            <td class="px-5 py-3.5">
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                    style={`background-color:${statusColor[b.status]}`}>
                {statusLabel[b.status]}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
