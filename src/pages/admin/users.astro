---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { supabaseAdmin } from '../../lib/supabase'

let message = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()
  const id     = form.get('id')?.toString()

  if (action === 'make_host') {
    await supabaseAdmin.from('profiles').update({ role: 'host' }).eq('id', id!)
    message = 'Rol actualizado a Host.'
  } else if (action === 'make_admin') {
    await supabaseAdmin.from('profiles').update({ role: 'admin' }).eq('id', id!)
    message = 'Rol actualizado a Admin.'
  } else if (action === 'make_traveler') {
    await supabaseAdmin.from('profiles').update({ role: 'traveler' }).eq('id', id!)
    message = 'Rol actualizado a Viajero.'
  }
}

const { data: users } = await supabaseAdmin
  .from('profiles')
  .select('id, full_name, role, created_at')
  .order('created_at', { ascending: false })

const roleColor: Record<string, string> = { admin: '#6D4C3D', host: '#2E593F', traveler: '#F27C38' }
const roleLabel: Record<string, string> = { admin: 'Admin', host: 'Host', traveler: 'Viajero' }
---

<AdminLayout title="Usuarios" active="/admin/users">
  {message && (
    <div class="mb-4 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">{message}</div>
  )}

  <div class="bg-white rounded-2xl border overflow-hidden" style="border-color:#e8ddd4">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left" style="border-color:#e8ddd4;background-color:#faf8f5">
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Usuario</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Rol</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 hidden sm:table-cell">Registrado</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Cambiar rol</th>
        </tr>
      </thead>
      <tbody class="divide-y" style="divide-color:#f0e8e0">
        {(users ?? []).map((u: any) => (
          <tr>
            <td class="px-5 py-3.5">
              <p class="font-medium text-gray-900">{u.full_name || '(sin nombre)'}</p>
            </td>
            <td class="px-5 py-3.5">
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                    style={`background-color:${roleColor[u.role]}`}>
                {roleLabel[u.role]}
              </span>
            </td>
            <td class="px-5 py-3.5 text-gray-400 text-xs hidden sm:table-cell">
              {new Date(u.created_at).toLocaleDateString('es-CL')}
            </td>
            <td class="px-5 py-3.5">
              <div class="flex gap-2 flex-wrap">
                {u.role !== 'host' && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="make_host" />
                    <input type="hidden" name="id" value={u.id} />
                    <button class="text-xs px-2.5 py-1 rounded-lg font-semibold hover:opacity-80 text-white" style="background-color:#2E593F">
                      → Host
                    </button>
                  </form>
                )}
                {u.role !== 'traveler' && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="make_traveler" />
                    <input type="hidden" name="id" value={u.id} />
                    <button class="text-xs px-2.5 py-1 rounded-lg font-semibold hover:opacity-80" style="background-color:#fef0e6;color:#F27C38">
                      → Viajero
                    </button>
                  </form>
                )}
                {u.role !== 'admin' && (
                  <form method="POST" class="inline"
                        onsubmit="return confirm('¿Dar permisos de Admin a este usuario?')">
                    <input type="hidden" name="action" value="make_admin" />
                    <input type="hidden" name="id" value={u.id} />
                    <button class="text-xs px-2.5 py-1 rounded-lg font-semibold hover:opacity-80" style="background-color:#f3ece8;color:#6D4C3D">
                      → Admin
                    </button>
                  </form>
                )}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
