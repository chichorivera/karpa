---
import AdminLayout from '../../layouts/AdminLayout.astro'
import { supabaseAdmin } from '../../lib/supabase'

let message = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()
  const id     = form.get('id')?.toString()

  if (action === 'activate') {
    await supabaseAdmin.from('campings').update({ status: 'active' }).eq('id', id!)
    message = 'Camping activado.'
  } else if (action === 'pause') {
    await supabaseAdmin.from('campings').update({ status: 'paused' }).eq('id', id!)
    message = 'Camping pausado.'
  } else if (action === 'delete') {
    await supabaseAdmin.from('campings').delete().eq('id', id!)
    message = 'Camping eliminado.'
  }
}

const { data: campings } = await supabaseAdmin
  .from('campings')
  .select('id, name, city, status, created_at, profiles!owner_id(full_name)')
  .order('created_at', { ascending: false })

const statusColor: Record<string, string> = { draft: '#D9C3A5', active: '#2E593F', paused: '#F27C38' }
const statusLabel: Record<string, string> = { draft: 'Borrador', active: 'Activo', paused: 'Pausado' }
---

<AdminLayout title="Campings" active="/admin/campings">
  {message && (
    <div class="mb-4 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">{message}</div>
  )}

  <div class="bg-white rounded-2xl border overflow-hidden" style="border-color:#e8ddd4">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b text-left" style="border-color:#e8ddd4;background-color:#faf8f5">
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Camping</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500 hidden sm:table-cell">Propietario</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Estado</th>
          <th class="px-5 py-3 text-xs font-semibold text-gray-500">Acciones</th>
        </tr>
      </thead>
      <tbody class="divide-y" style="divide-color:#f0e8e0">
        {(campings ?? []).map((c: any) => (
          <tr>
            <td class="px-5 py-3.5">
              <p class="font-medium text-gray-900">{c.name}</p>
              <p class="text-xs text-gray-400">{c.city}</p>
            </td>
            <td class="px-5 py-3.5 text-gray-500 hidden sm:table-cell">{c.profiles?.full_name ?? '—'}</td>
            <td class="px-5 py-3.5">
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                    style={`background-color:${statusColor[c.status]}`}>
                {statusLabel[c.status]}
              </span>
            </td>
            <td class="px-5 py-3.5">
              <div class="flex gap-2">
                {c.status !== 'active' && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="activate" />
                    <input type="hidden" name="id" value={c.id} />
                    <button class="text-xs font-semibold px-2.5 py-1 rounded-lg hover:opacity-80 text-white" style="background-color:#2E593F">
                      Activar
                    </button>
                  </form>
                )}
                {c.status === 'active' && (
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="pause" />
                    <input type="hidden" name="id" value={c.id} />
                    <button class="text-xs font-semibold px-2.5 py-1 rounded-lg hover:opacity-80" style="background-color:#fef0e6;color:#F27C38">
                      Pausar
                    </button>
                  </form>
                )}
                <form method="POST" class="inline"
                      onsubmit="return confirm('¿Eliminar este camping? Esta acción no se puede deshacer.')">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={c.id} />
                  <button class="text-xs font-semibold px-2.5 py-1 rounded-lg hover:opacity-80" style="background-color:#fee2e2;color:#ef4444">
                    Eliminar
                  </button>
                </form>
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
