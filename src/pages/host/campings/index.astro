---
import HostLayout from '../../../layouts/HostLayout.astro'
import { supabase } from '../../../lib/supabase'

const userId = 'demo' // TODO: sesión real

const { data: campings } = await supabase
  .from('campings')
  .select('id, name, city, status, created_at')
  .eq('owner_id', userId)
  .order('created_at', { ascending: false })

const statusLabel: Record<string, string> = {
  draft:  'Borrador',
  active: 'Activo',
  paused: 'Pausado',
}
const statusColor: Record<string, string> = {
  draft:  '#D9C3A5',
  active: '#2E593F',
  paused: '#F27C38',
}
---

<HostLayout title="Mis Campings" active="/host/campings">

  {!campings?.length ? (
    <div class="max-w-md mx-auto text-center py-20">
      <div class="w-20 h-20 rounded-2xl mx-auto mb-5 flex items-center justify-center text-4xl"
           style="background-color:#F4E8D4">⛺</div>
      <h2 class="text-xl font-bold mb-2 text-gray-900" style="font-family:'Playfair Display',serif">
        Aún no tienes campings
      </h2>
      <p class="text-gray-500 text-sm mb-6">
        Crea tu primer camping y empieza a recibir reservas de viajeros.
      </p>
      <a href="/host/campings/new"
         class="inline-flex items-center gap-2 px-5 py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
         style="background-color:#6D4C3D">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Crear mi primer camping
      </a>
    </div>
  ) : (
    <div>
      <div class="flex items-center justify-between mb-6">
        <p class="text-sm text-gray-500">{campings.length} camping{campings.length !== 1 ? 's' : ''}</p>
        <a href="/host/campings/new"
           class="flex items-center gap-2 px-4 py-2 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition lg:hidden"
           style="background-color:#F27C38">
          + Nuevo
        </a>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {campings.map(c => (
          <div class="bg-white rounded-2xl border overflow-hidden hover:shadow-md transition-shadow" style="border-color:#e8ddd4">
            <!-- Placeholder imagen -->
            <div class="h-36 flex items-center justify-center text-5xl" style="background-color:#F4E8D4">⛺</div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-semibold text-gray-900 text-sm leading-snug">{c.name}</h3>
                <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                      style={`background-color:${statusColor[c.status]}`}>
                  {statusLabel[c.status]}
                </span>
              </div>
              {c.city && <p class="text-xs text-gray-400 mb-4">{c.city}</p>}
              <div class="flex gap-2">
                <a href={`/host/campings/${c.id}`}
                   class="flex-1 text-center py-2 rounded-xl text-xs font-semibold transition hover:opacity-80"
                   style="background-color:#F4E8D4;color:#6D4C3D">
                  Editar
                </a>
                <a href={`/host/campings/${c.id}/units`}
                   class="flex-1 text-center py-2 rounded-xl text-xs font-semibold transition hover:opacity-80"
                   style="background-color:#e8f3ec;color:#2E593F">
                  Parcelas
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</HostLayout>
