---
import HostLayout from '../../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../../lib/supabase'

const { user } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

const { data: campings } = await supabaseAdmin
  .from('campings')
  .select('id, name, city, status, created_at')
  .eq('owner_id', user.id)
  .order('created_at', { ascending: false })

const statusLabel: Record<string, string> = { draft: 'Borrador', active: 'Activo', paused: 'Pausado' }
const statusColor: Record<string, string> = { draft: '#D9C3A5', active: '#2E593F', paused: '#F27C38' }
---

<HostLayout title="Mis Campings" active="/host/campings">
  {!campings?.length ? (
    <div class="max-w-md mx-auto text-center py-20">
      <div class="w-20 h-20 rounded-2xl mx-auto mb-5 flex items-center justify-center opacity-40" style="background-color:#F4E8D4"><img src="/favicon.png" alt="" class="w-12 h-12 object-contain" /></div>
      <h2 class="text-xl font-bold mb-2 text-gray-900" style="font-family:'Playfair Display',serif">Aún no tienes campings</h2>
      <p class="text-gray-500 text-sm mb-6">Crea tu primer camping y empieza a recibir reservas.</p>
      <a href="/host/campings/new"
         class="inline-flex items-center gap-2 px-5 py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
         style="background-color:#6D4C3D">
        Crear mi primer camping
      </a>
    </div>
  ) : (
    <div>
      <p class="text-sm text-gray-500 mb-6">{campings.length} camping{campings.length !== 1 ? 's' : ''}</p>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {campings.map((c: any) => (
          <div class="bg-white rounded-2xl border overflow-hidden hover:shadow-md transition-shadow" style="border-color:#e8ddd4">
            <div class="h-36 flex items-center justify-center opacity-30" style="background-color:#F4E8D4"><img src="/favicon.png" alt="" class="w-14 h-14 object-contain" /></div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h3 class="font-semibold text-gray-900 text-sm leading-snug">{c.name}</h3>
                <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full text-white"
                      style={`background-color:${statusColor[c.status]}`}>
                  {statusLabel[c.status]}
                </span>
              </div>
              {c.city && <p class="text-xs text-gray-400 mb-4">{c.city}</p>}
              <div class="flex gap-2">
                <a href={`/host/campings/${c.id}`}
                   class="flex-1 text-center py-2 rounded-xl text-xs font-semibold hover:opacity-80 transition"
                   style="background-color:#F4E8D4;color:#6D4C3D">Editar</a>
                <a href={`/host/campings/${c.id}/units`}
                   class="flex-1 text-center py-2 rounded-xl text-xs font-semibold hover:opacity-80 transition"
                   style="background-color:#e8f3ec;color:#2E593F">Parcelas</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}
</HostLayout>
