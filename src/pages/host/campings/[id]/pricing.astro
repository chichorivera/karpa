---
import HostLayout from '../../../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../../../lib/supabase'

const { user } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

const { id: campingId } = Astro.params

const { data: camping } = await supabaseAdmin
  .from('campings').select('id, name').eq('id', campingId!).eq('owner_id', user.id).single()

if (!camping) return Astro.redirect('/host/campings')

const { data: units } = await supabaseAdmin
  .from('units').select('id, name, type, price_per_night').eq('camping_id', campingId!).eq('status', 'active').order('created_at')

let error = ''
let success = ''

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()

  if (action === 'add') {
    const unitId    = form.get('unitId')?.toString()
    const dateFrom  = form.get('date_from')?.toString()
    const dateTo    = form.get('date_to')?.toString()
    const price     = Number(form.get('price'))
    const label     = form.get('label')?.toString() ?? ''

    if (!unitId || !dateFrom || !dateTo || !price) {
      error = 'Completa todos los campos requeridos.'
    } else {
      const { error: e } = await supabaseAdmin.from('unit_pricing').insert({
        unit_id: unitId, date_from: dateFrom, date_to: dateTo, price_per_night: price,
        label: label || null,
      })
      if (e) error = `Error: ${e.message}`
      else success = 'Precio especial guardado.'
    }
  }

  if (action === 'delete') {
    const pricingId = form.get('pricingId')?.toString()
    await supabaseAdmin.from('unit_pricing').delete().eq('id', pricingId!)
    success = 'Precio eliminado.'
  }
}

const unitIds = units?.map(u => u.id) ?? []
const { data: pricingRules } = unitIds.length
  ? await supabaseAdmin.from('unit_pricing')
      .select('id, unit_id, date_from, date_to, price_per_night, label')
      .in('unit_id', unitIds)
      .order('date_from')
  : { data: [] }

const unitMap = Object.fromEntries((units ?? []).map((u: any) => [u.id, u]))

const typeLabel: Record<string, string> = {
  tent: 'Sitio', cabin: 'Cabaña', glamping: 'Glamping', camper: 'Camper', other: 'Otro',
}

function formatDate(d: string) {
  return new Date(d + 'T12:00:00').toLocaleDateString('es-CL', { day: 'numeric', month: 'short', year: 'numeric' })
}
---

<HostLayout title={`Precios — ${camping.name}`} active="/host/campings">
  <div class="max-w-3xl mx-auto">
    <a href={`/host/campings/${campingId}`} class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-6 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a {camping.name}
    </a>

    {success && <div class="mb-4 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">{success}</div>}
    {error   && <div class="mb-4 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100">{error}</div>}

    {!units?.length && (
      <div class="bg-amber-50 border border-amber-100 rounded-xl px-4 py-3 text-sm text-amber-700 mb-6">
        Primero debes crear unidades activas para poder configurar precios especiales.
      </div>
    )}

    <!-- Precio base info -->
    {units && units.length > 0 && (
      <div class="bg-white rounded-2xl border p-6 mb-6" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900 mb-4" style="font-family:'Playfair Display',serif">Precios base por unidad</h2>
        <div class="space-y-2">
          {units.map((u: any) => (
            <div class="flex items-center justify-between py-2 border-b last:border-0 text-sm" style="border-color:#f0ebe5">
              <div class="flex items-center gap-2">
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white" style="background-color:#2E593F">{typeLabel[u.type] ?? u.type}</span>
                <span class="text-gray-700">{u.name}</span>
              </div>
              <span class="font-semibold text-gray-900">${Number(u.price_per_night).toLocaleString('es-CL')}/noche</span>
            </div>
          ))}
        </div>
        <p class="text-xs text-gray-400 mt-3">El precio base se aplica cuando no hay precio especial para esas fechas.</p>
      </div>
    )}

    <!-- Precios especiales existentes -->
    {pricingRules && pricingRules.length > 0 && (
      <div class="bg-white rounded-2xl border p-6 mb-6" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900 mb-4" style="font-family:'Playfair Display',serif">Precios especiales configurados</h2>
        <div class="space-y-3">
          {pricingRules.map((r: any) => {
            const unit = unitMap[r.unit_id]
            return (
              <div class="flex items-center gap-4 py-3 border-b last:border-0" style="border-color:#f0ebe5">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full text-white" style="background-color:#2E593F">
                      {typeLabel[unit?.type] ?? ''}
                    </span>
                    <span class="text-sm font-medium text-gray-800">{unit?.name}</span>
                    {r.label && <span class="text-xs text-gray-400">· {r.label}</span>}
                  </div>
                  <p class="text-xs text-gray-500">
                    {formatDate(r.date_from)} → {formatDate(r.date_to)}
                  </p>
                </div>
                <div class="text-right shrink-0">
                  <p class="font-semibold text-sm" style="color:#6D4C3D">${Number(r.price_per_night).toLocaleString('es-CL')}/noche</p>
                  <form method="POST" class="mt-1">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="pricingId" value={r.id} />
                    <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition"
                            onclick="return confirm('¿Eliminar este precio?')">Eliminar</button>
                  </form>
                </div>
              </div>
            )
          })}
        </div>
      </div>
    )}

    <!-- Formulario nuevo precio especial -->
    {units && units.length > 0 && (
      <div class="bg-white rounded-2xl border p-6" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900 mb-5" style="font-family:'Playfair Display',serif">Agregar precio especial</h2>
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="add" />
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Unidad <span class="text-red-400">*</span></label>
            <select name="unitId" required class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5">
              <option value="">Selecciona una unidad</option>
              {units.map((u: any) => (
                <option value={u.id}>{u.name} (base: ${Number(u.price_per_night).toLocaleString('es-CL')})</option>
              ))}
            </select>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Fecha inicio <span class="text-red-400">*</span></label>
              <input name="date_from" type="date" required
                class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Fecha fin <span class="text-red-400">*</span></label>
              <input name="date_to" type="date" required
                class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Precio por noche ($CLP) <span class="text-red-400">*</span></label>
              <input name="price" type="number" min="1000" step="1000" required placeholder="45000"
                class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Etiqueta (opcional)</label>
              <input name="label" type="text" placeholder="Ej: Temporada alta, Fiestas Patrias"
                class="w-full px-4 py-3 rounded-xl border text-sm outline-none placeholder:text-gray-400" style="border-color:#D9C3A5" />
            </div>
          </div>
          <button type="submit"
            class="w-full py-3.5 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
            style="background-color:#6D4C3D">
            Guardar precio especial
          </button>
        </form>
      </div>
    )}
  </div>
</HostLayout>
