---
import HostLayout from '../../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../../lib/supabase'

const { user } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

const { id } = Astro.params
const created = Astro.url.searchParams.get('created') === '1'

const { data: camping } = await supabaseAdmin
  .from('campings')
  .select('id, name, description, city, address, rules, status, lat, lng')
  .eq('id', id!)
  .eq('owner_id', user.id)
  .single()

if (!camping) return Astro.redirect('/host/campings')

let error = ''
let success = false

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData()
  const action = form.get('action')?.toString()

  if (action === 'update') {
    const latVal = form.get('lat')?.toString()
    const lngVal = form.get('lng')?.toString()
    const { error: dbError } = await supabaseAdmin
      .from('campings')
      .update({
        name:        form.get('name')?.toString(),
        description: form.get('description')?.toString(),
        city:        form.get('city')?.toString(),
        address:     form.get('address')?.toString(),
        rules:       form.get('rules')?.toString(),
        status:      form.get('status')?.toString(),
        lat:         latVal ? Number(latVal) : null,
        lng:         lngVal ? Number(lngVal) : null,
      })
      .eq('id', id!)
    if (dbError) error = 'Error al guardar los cambios.'
    else success = true
  }

  if (action === 'upload-images') {
    const files = form.getAll('images') as File[]
    const { data: existingImgs } = await supabaseAdmin
      .from('camping_images').select('order').eq('camping_id', id!).order('order', { ascending: false }).limit(1)
    let nextOrder = existingImgs?.[0] ? (existingImgs[0] as any).order + 1 : 0

    for (const file of files) {
      if (!(file instanceof File) || file.size === 0) continue
      const ext  = file.name.split('.').pop() ?? 'jpg'
      const path = `${id}/${Date.now()}-${Math.random().toString(36).slice(2)}.${ext}`
      const buf  = await file.arrayBuffer()
      const { error: upErr } = await supabaseAdmin.storage
        .from('camping-images')
        .upload(path, buf, { contentType: file.type, upsert: false })
      if (upErr) { error = `Error subiendo imagen: ${upErr.message}`; break }
      const { data: { publicUrl } } = supabaseAdmin.storage.from('camping-images').getPublicUrl(path)
      await supabaseAdmin.from('camping_images').insert({
        camping_id: id, url: publicUrl, order: nextOrder++, is_cover: nextOrder === 1,
      })
    }
    if (!error) success = true
  }

  if (action === 'delete-image') {
    const imageId  = form.get('imageId')?.toString()
    const imageUrl = form.get('imageUrl')?.toString() ?? ''
    const urlObj   = new URL(imageUrl)
    const storagePath = urlObj.pathname.split('/object/public/camping-images/')[1]
    if (storagePath) await supabaseAdmin.storage.from('camping-images').remove([storagePath])
    await supabaseAdmin.from('camping_images').delete().eq('id', imageId!)
    success = true
  }

  if (action === 'set-cover') {
    const imageId = form.get('imageId')?.toString()
    await supabaseAdmin.from('camping_images').update({ is_cover: false }).eq('camping_id', id!)
    await supabaseAdmin.from('camping_images').update({ is_cover: true }).eq('id', imageId!)
    success = true
  }
}

const { data: images } = await supabaseAdmin
  .from('camping_images').select('id, url, is_cover, order').eq('camping_id', id!).order('order')
---

<HostLayout title="Editar Camping" active="/host/campings">
  <div class="max-w-2xl mx-auto">
    <a href="/host/campings" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-6 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Mis campings
    </a>

    {created && (
      <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">
        ✅ Camping creado. Agrega fotos y <a href={`/host/campings/${id}/units`} class="font-semibold underline">unidades de alojamiento</a>.
      </div>
    )}
    {success && <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">Cambios guardados.</div>}
    {error && <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100">{error}</div>}

    <form method="POST" class="space-y-6">
      <input type="hidden" name="action" value="update" />

      <div class="bg-white rounded-2xl border p-6 space-y-5" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Información básica</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre</label>
          <input name="name" type="text" required value={camping.name}
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Descripción</label>
          <textarea name="description" rows="4"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none resize-none"
            style="border-color:#D9C3A5">{camping.description}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Estado</label>
          <select name="status" class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5">
            <option value="draft"  selected={camping.status === 'draft'}>Borrador</option>
            <option value="active" selected={camping.status === 'active'}>Activo</option>
            <option value="paused" selected={camping.status === 'paused'}>Pausado</option>
          </select>
        </div>
      </div>

      <div class="bg-white rounded-2xl border p-6 space-y-4" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Ubicación</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Ciudad</label>
            <input name="city" type="text" value={camping.city ?? ''}
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Dirección</label>
            <input name="address" type="text" value={camping.address ?? ''}
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
          </div>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label class="text-sm font-medium text-gray-700">Coordenadas (haz clic en el mapa)</label>
            <button type="button" id="geocode-btn"
              class="text-xs font-semibold px-3 py-1 rounded-lg border transition hover:bg-gray-50"
              style="border-color:#D9C3A5;color:#2E593F">
              Buscar ciudad en mapa
            </button>
          </div>
          <div class="grid grid-cols-2 gap-3 mb-3">
            <div>
              <label class="block text-xs text-gray-400 mb-1">Latitud</label>
              <input id="lat-input" name="lat" type="number" step="0.000001"
                value={camping.lat ?? ''} placeholder="-38.739228"
                class="w-full px-3 py-2 rounded-xl border text-sm outline-none placeholder:text-gray-300"
                style="border-color:#D9C3A5" />
            </div>
            <div>
              <label class="block text-xs text-gray-400 mb-1">Longitud</label>
              <input id="lng-input" name="lng" type="number" step="0.000001"
                value={camping.lng ?? ''} placeholder="-72.595887"
                class="w-full px-3 py-2 rounded-xl border text-sm outline-none placeholder:text-gray-300"
                style="border-color:#D9C3A5" />
            </div>
          </div>
          <div id="picker-map" style="height:260px;border-radius:0.75rem;overflow:hidden;border:1px solid #D9C3A5"></div>
          <p class="text-xs text-gray-400 mt-1.5">Haz clic en el mapa para marcar la ubicación exacta del camping</p>
        </div>
      </div>

      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
      <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
      <script type="application/json" id="camping-coords" set:html={JSON.stringify({ lat: camping.lat, lng: camping.lng })}></script>
      <script is:inline>
        const coords = JSON.parse(document.getElementById('camping-coords').textContent)
        const initLat = coords.lat ?? -38, initLng = coords.lng ?? -72, initZoom = coords.lat ? 13 : 5
        const pickerMap = L.map('picker-map').setView([initLat, initLng], initZoom)
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap'
        }).addTo(pickerMap)

        let marker = coords.lat ? L.marker([coords.lat, coords.lng]).addTo(pickerMap) : null
        const latInput = document.getElementById('lat-input')
        const lngInput = document.getElementById('lng-input')

        function placeMarker(lat, lng) {
          latInput.value = lat.toFixed(6)
          lngInput.value = lng.toFixed(6)
          if (marker) marker.setLatLng([lat, lng])
          else marker = L.marker([lat, lng]).addTo(pickerMap)
        }

        pickerMap.on('click', e => placeMarker(e.latlng.lat, e.latlng.lng))

        latInput.addEventListener('change', () => {
          const lat = parseFloat(latInput.value), lng = parseFloat(lngInput.value)
          if (!isNaN(lat) && !isNaN(lng)) { placeMarker(lat, lng); pickerMap.setView([lat, lng], 13) }
        })
        lngInput.addEventListener('change', () => {
          const lat = parseFloat(latInput.value), lng = parseFloat(lngInput.value)
          if (!isNaN(lat) && !isNaN(lng)) { placeMarker(lat, lng); pickerMap.setView([lat, lng], 13) }
        })

        document.getElementById('geocode-btn').addEventListener('click', async () => {
          const city = document.querySelector('[name="city"]').value.trim()
          if (!city) return
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(city + ' Chile')}&limit=1`)
          const data = await res.json()
          if (data[0]) { placeMarker(parseFloat(data[0].lat), parseFloat(data[0].lon)); pickerMap.setView([parseFloat(data[0].lat), parseFloat(data[0].lon)], 12) }
        })
      </script>

      <div class="bg-white rounded-2xl border p-6 space-y-4" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Reglas</h2>
        <textarea name="rules" rows="3"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none resize-none"
          style="border-color:#D9C3A5">{camping.rules}</textarea>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href={`/host/campings/${id}/units`}
           class="flex-1 text-center py-3.5 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
           style="border-color:#D9C3A5;color:#2E593F">
          Gestionar unidades →
        </a>
        <a href={`/host/campings/${id}/pricing`}
           class="flex-1 text-center py-3.5 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
           style="border-color:#D9C3A5;color:#F27C38">
          Precios especiales →
        </a>
        <button type="submit"
          class="flex-1 py-3.5 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
          style="background-color:#6D4C3D">
          Guardar cambios
        </button>
      </div>
    </form>

    <!-- Fotos -->
    <div class="bg-white rounded-2xl border p-6 mt-6" style="border-color:#e8ddd4">
      <h2 class="font-semibold text-gray-900 mb-4" style="font-family:'Playfair Display',serif">Fotos del camping</h2>

      {images && images.length > 0 && (
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-5">
          {images.map((img: any) => (
            <div class="relative group rounded-xl overflow-hidden aspect-video bg-gray-100">
              <img src={img.url} alt="" class="w-full h-full object-cover" />
              {img.is_cover && (
                <span class="absolute top-1.5 left-1.5 text-xs font-semibold px-2 py-0.5 rounded-full text-white" style="background-color:#F27C38">Portada</span>
              )}
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center gap-2">
                {!img.is_cover && (
                  <form method="POST">
                    <input type="hidden" name="action" value="set-cover" />
                    <input type="hidden" name="imageId" value={img.id} />
                    <button type="submit" class="text-xs bg-white text-gray-800 font-semibold px-2 py-1 rounded-lg hover:bg-gray-100 transition">
                      Portada
                    </button>
                  </form>
                )}
                <form method="POST">
                  <input type="hidden" name="action" value="delete-image" />
                  <input type="hidden" name="imageId" value={img.id} />
                  <input type="hidden" name="imageUrl" value={img.url} />
                  <button type="submit" class="text-xs bg-red-500 text-white font-semibold px-2 py-1 rounded-lg hover:bg-red-600 transition"
                          onclick="return confirm('¿Eliminar esta foto?')">
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}

      <form method="POST" enctype="multipart/form-data" class="space-y-3">
        <input type="hidden" name="action" value="upload-images" />
        <label class="block">
          <div id="drop-zone" class="border-2 border-dashed rounded-xl p-8 text-center cursor-pointer transition hover:border-[#6D4C3D]" style="border-color:#D9C3A5">
            <svg class="w-8 h-8 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm font-medium text-gray-600">Arrastra fotos aquí o haz clic para seleccionar</p>
            <p class="text-xs text-gray-400 mt-1">JPG, PNG, WebP · máx. 5 MB por foto</p>
            <p id="file-count" class="text-xs font-semibold mt-2" style="color:#6D4C3D"></p>
          </div>
          <input id="img-input" name="images" type="file" accept="image/*" multiple class="hidden" />
        </label>
        <button type="submit" id="upload-btn"
          class="w-full py-3 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition hidden"
          style="background-color:#6D4C3D">
          Subir fotos
        </button>
      </form>
    </div>
  </div>
</HostLayout>

<script>
  const input     = document.getElementById('img-input') as HTMLInputElement
  const dropZone  = document.getElementById('drop-zone')!
  const fileCount = document.getElementById('file-count')!
  const uploadBtn = document.getElementById('upload-btn')!

  dropZone.addEventListener('click', () => input.click())

  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.borderColor = '#6D4C3D' })
  dropZone.addEventListener('dragleave', () => dropZone.style.borderColor = '#D9C3A5')
  dropZone.addEventListener('drop', e => {
    e.preventDefault()
    dropZone.style.borderColor = '#D9C3A5'
    if (e.dataTransfer?.files) {
      const dt = new DataTransfer()
      Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f))
      input.files = dt.files
      updateCount()
    }
  })

  input.addEventListener('change', updateCount)

  function updateCount() {
    const n = input.files?.length ?? 0
    if (n > 0) {
      fileCount.textContent = `${n} foto${n > 1 ? 's' : ''} seleccionada${n > 1 ? 's' : ''}`
      uploadBtn.classList.remove('hidden')
    } else {
      fileCount.textContent = ''
      uploadBtn.classList.add('hidden')
    }
  }
</script>
