---
import HostLayout from '../../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../../lib/supabase'

const { user } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

let error = ''

if (Astro.request.method === 'POST') {
  const form        = await Astro.request.formData()
  const name        = form.get('name')?.toString() ?? ''
  const description = form.get('description')?.toString() ?? ''
  const city        = form.get('city')?.toString() ?? ''
  const address     = form.get('address')?.toString() ?? ''
  const rules       = form.get('rules')?.toString() ?? ''
  const publish     = form.get('publish') === 'true'

  const { data: slugData } = await supabaseAdmin.rpc('generate_slug', { name })
  const slug = slugData ?? name.toLowerCase().replace(/[^a-z0-9]+/g, '-')

  const { data: camping, error: dbError } = await supabaseAdmin
    .from('campings')
    .insert({ owner_id: user.id, name, slug, description, city, address, rules, status: publish ? 'active' : 'draft' })
    .select('id').single()

  if (dbError) error = 'Error al crear el camping. Intenta nuevamente.'
  else return Astro.redirect(`/host/campings/${camping.id}?created=1`)
}
---

<HostLayout title="Nuevo Camping" active="/host/campings">
  <div class="max-w-2xl mx-auto">
    <a href="/host/campings" class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-6 transition">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a mis campings
    </a>

    {error && <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100">{error}</div>}

    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-2xl border p-6 space-y-5" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Información básica</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="name">Nombre del camping <span class="text-red-400">*</span></label>
          <input id="name" name="name" type="text" required placeholder="Ej: Camping Río Claro"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition placeholder:text-gray-400"
            style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5" for="description">Descripción</label>
          <textarea id="description" name="description" rows="4"
            placeholder="Describe tu camping: entorno, ambiente, qué lo hace especial..."
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none resize-none placeholder:text-gray-400"
            style="border-color:#D9C3A5"></textarea>
        </div>
      </div>

      <div class="bg-white rounded-2xl border p-6 space-y-5" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Ubicación</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="city">Ciudad / Comuna</label>
            <input id="city" name="city" type="text" placeholder="Ej: Pucón"
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none placeholder:text-gray-400"
              style="border-color:#D9C3A5" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5" for="address">Dirección o referencia</label>
            <input id="address" name="address" type="text" placeholder="Ruta 5 Sur, km 780"
              class="w-full px-4 py-3 rounded-xl border text-sm outline-none placeholder:text-gray-400"
              style="border-color:#D9C3A5" />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border p-6 space-y-4" style="border-color:#e8ddd4">
        <h2 class="font-semibold text-gray-900" style="font-family:'Playfair Display',serif">Reglas</h2>
        <textarea id="rules" name="rules" rows="3"
          placeholder="Ej: No mascotas, silencio desde las 23hrs..."
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none resize-none placeholder:text-gray-400"
          style="border-color:#D9C3A5"></textarea>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <button type="submit" name="publish" value="false"
          class="flex-1 py-3.5 rounded-xl text-sm font-semibold border transition hover:bg-gray-50"
          style="border-color:#D9C3A5;color:#6D4C3D">
          Guardar borrador
        </button>
        <button type="submit" name="publish" value="true"
          class="flex-1 py-3.5 rounded-xl text-white text-sm font-semibold transition hover:opacity-90"
          style="background-color:#6D4C3D">
          Publicar camping
        </button>
      </div>
    </form>
  </div>
</HostLayout>
