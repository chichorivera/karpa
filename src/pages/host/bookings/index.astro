---
import HostLayout from '../../../layouts/HostLayout.astro'
import { supabase } from '../../../lib/supabase'

const userId = 'demo' // TODO: sesión real

const { data: campings } = await supabase
  .from('campings')
  .select('id')
  .eq('owner_id', userId)

const campingIds = campings?.map(c => c.id) ?? []

const { data: bookings } = campingIds.length
  ? await supabase
      .from('bookings')
      .select(`
        id, check_in, check_out, guests, total_price, status, created_at,
        units(name),
        campings(name),
        profiles!traveler_id(full_name)
      `)
      .in('camping_id', campingIds)
      .order('created_at', { ascending: false })
  : { data: [] }

const statusLabel: Record<string, string> = {
  pending:   'Pendiente',
  confirmed: 'Confirmada',
  cancelled: 'Cancelada',
  completed: 'Completada',
}
const statusBg: Record<string, string> = {
  pending:   '#fef0e6',
  confirmed: '#e8f3ec',
  cancelled: '#fee2e2',
  completed: '#f3f4f6',
}
const statusText: Record<string, string> = {
  pending:   '#F27C38',
  confirmed: '#2E593F',
  cancelled: '#ef4444',
  completed: '#6b7280',
}
---

<HostLayout title="Reservas" active="/host/bookings">
  {!bookings?.length ? (
    <div class="max-w-md mx-auto text-center py-20">
      <div class="w-20 h-20 rounded-2xl mx-auto mb-5 flex items-center justify-center text-4xl"
           style="background-color:#F4E8D4">📋</div>
      <h2 class="text-xl font-bold mb-2 text-gray-900" style="font-family:'Playfair Display',serif">
        Aún no tienes reservas
      </h2>
      <p class="text-gray-500 text-sm">
        Cuando un viajero reserve tu camping, aparecerá aquí.
      </p>
    </div>
  ) : (
    <div class="space-y-3">
      {bookings.map((b: any) => (
        <div class="bg-white rounded-2xl border p-5 flex flex-col sm:flex-row sm:items-center gap-4" style="border-color:#e8ddd4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <p class="text-sm font-semibold text-gray-900 truncate">
                {b.profiles?.full_name ?? 'Viajero'}
              </p>
              <span class="shrink-0 text-xs font-semibold px-2 py-0.5 rounded-full"
                    style={`background-color:${statusBg[b.status]};color:${statusText[b.status]}`}>
                {statusLabel[b.status]}
              </span>
            </div>
            <p class="text-xs text-gray-500">
              {b.campings?.name} · {b.units?.name}
            </p>
            <p class="text-xs text-gray-400 mt-1">
              {new Date(b.check_in).toLocaleDateString('es-CL')} → {new Date(b.check_out).toLocaleDateString('es-CL')}
              · {b.guests} persona{b.guests !== 1 ? 's' : ''}
            </p>
          </div>

          <div class="flex items-center gap-3 shrink-0">
            <p class="text-base font-bold" style="color:#6D4C3D">
              ${Number(b.total_price).toLocaleString('es-CL')}
            </p>

            {b.status === 'pending' && (
              <div class="flex gap-2">
                <form action="/api/host/bookings/confirm" method="POST">
                  <input type="hidden" name="bookingId" value={b.id} />
                  <button class="px-3 py-1.5 rounded-xl text-xs font-semibold text-white hover:opacity-80 transition"
                          style="background-color:#2E593F">
                    Confirmar
                  </button>
                </form>
                <form action="/api/host/bookings/reject" method="POST">
                  <input type="hidden" name="bookingId" value={b.id} />
                  <button class="px-3 py-1.5 rounded-xl text-xs font-semibold hover:opacity-80 transition"
                          style="background-color:#fee2e2;color:#ef4444">
                    Rechazar
                  </button>
                </form>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</HostLayout>
