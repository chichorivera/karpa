---
import HostLayout from '../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../lib/supabase'

const { user, profile } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

let success = false
let error   = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const { error: e } = await supabaseAdmin
    .from('profiles')
    .update({ full_name: form.get('full_name')?.toString(), phone: form.get('phone')?.toString() })
    .eq('id', user.id)
  if (e) error = 'Error al guardar.'
  else success = true
}

const avatarUrl = profile?.avatar_url ?? null
const initials  = (profile?.full_name ?? user.email ?? 'H')[0].toUpperCase()
---

<HostLayout title="Mi Perfil" active="/host/profile">
  <div class="max-w-lg mx-auto">
    {success && <div class="mb-5 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">Perfil actualizado.</div>}
    {error   && <div class="mb-5 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100">{error}</div>}

    <div class="bg-white border rounded-2xl p-6" style="border-color:#e8ddd4">
      <div class="flex items-center gap-4 mb-6 pb-6 border-b" style="border-color:#e8ddd4">
        <button type="button" id="avatar-btn" class="relative group shrink-0" title="Cambiar foto">
          {avatarUrl ? (
            <img id="avatar-preview" src={avatarUrl} alt="avatar"
                 class="w-16 h-16 rounded-full object-cover border-2" style="border-color:#D9C3A5" />
          ) : (
            <div id="avatar-preview" class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white"
                 style="background-color:#2E593F">{initials}</div>
          )}
          <div class="absolute inset-0 rounded-full bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
        </button>
        <input id="avatar-file" type="file" accept="image/*" class="hidden" />
        <div>
          <p class="font-semibold text-gray-900">{profile?.full_name ?? '(sin nombre)'}</p>
          <p class="text-sm text-gray-400">{user.email}</p>
          <button type="button" id="avatar-btn2" class="text-xs mt-1 hover:underline" style="color:#2E593F">Cambiar foto de perfil</button>
        </div>
      </div>
      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre completo</label>
          <input name="full_name" type="text" value={profile?.full_name ?? ''}
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Teléfono</label>
          <input name="phone" type="tel" value={profile?.phone ?? ''} placeholder="+56 9 1234 5678"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none placeholder:text-gray-400" style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
          <input type="email" value={user.email} disabled
            class="w-full px-4 py-3 rounded-xl border text-sm bg-gray-50 text-gray-400" style="border-color:#D9C3A5" />
        </div>
        <button type="submit"
          class="w-full py-3.5 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
          style="background-color:#6D4C3D">
          Guardar cambios
        </button>
      </form>
    </div>
  </div>

  <!-- Crop modal -->
  <div id="crop-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background:rgba(0,0,0,0.7)">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden">
      <div class="px-5 py-4 border-b flex items-center justify-between" style="border-color:#e8ddd4">
        <h3 class="font-semibold text-gray-900 text-sm">Recortar foto de perfil</h3>
        <button id="crop-close" class="p-1 rounded-lg hover:bg-gray-100">
          <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="p-4 flex flex-col items-center">
        <p class="text-xs text-gray-400 mb-3">Arrastra para reposicionar</p>
        <canvas id="crop-preview" width="280" height="280"
                style="display:block;width:280px;height:280px;border-radius:0.75rem;cursor:move;touch-action:none"></canvas>
        <canvas id="crop-output" width="400" height="400" style="display:none"></canvas>
        <img id="crop-src" style="display:none" alt="" />
        <div id="crop-error" class="text-xs text-red-500 mt-2 text-center hidden"></div>
        <div class="flex gap-3 mt-4 w-full">
          <button id="crop-cancel" type="button"
            class="flex-1 py-2.5 rounded-xl border text-sm font-semibold text-gray-600 hover:bg-gray-50 transition"
            style="border-color:#D9C3A5">Cancelar</button>
          <button id="crop-confirm" type="button"
            class="flex-1 py-2.5 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
            style="background-color:#2E593F">Confirmar</button>
        </div>
      </div>
    </div>
  </div>
</HostLayout>

<script>
  const C = 280, SQ = 240, OFF = 20

  const fileInput  = document.getElementById('avatar-file')  as HTMLInputElement
  const modal      = document.getElementById('crop-modal')!
  const preview    = document.getElementById('crop-preview')  as HTMLCanvasElement
  const output     = document.getElementById('crop-output')   as HTMLCanvasElement
  const srcImg     = document.getElementById('crop-src')      as HTMLImageElement
  const confirmBtn = document.getElementById('crop-confirm')!
  const cancelBtn  = document.getElementById('crop-cancel')!
  const closeBtn   = document.getElementById('crop-close')!
  const errorEl    = document.getElementById('crop-error')!
  const pCtx       = preview.getContext('2d')!
  const oCtx       = output.getContext('2d')!

  let ox = 0, oy = 0, scale = 1, dragging = false, dx = 0, dy = 0

  document.getElementById('avatar-btn')!.addEventListener('click',  () => fileInput.click())
  document.getElementById('avatar-btn2')!.addEventListener('click', () => fileInput.click())

  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0]
    if (!file) return
    const url = URL.createObjectURL(file)
    srcImg.onload = () => {
      const nw = srcImg.naturalWidth, nh = srcImg.naturalHeight
      scale = nw < nh ? C / nw : C / nh
      const w = nw * scale, h = nh * scale
      ox = (C - w) / 2
      oy = (C - h) / 2
      draw()
      modal.style.display = 'flex'
    }
    srcImg.src = url
  })

  function draw() {
    const w = srcImg.naturalWidth * scale, h = srcImg.naturalHeight * scale
    pCtx.clearRect(0, 0, C, C)
    pCtx.drawImage(srcImg, ox, oy, w, h)
    pCtx.fillStyle = 'rgba(0,0,0,0.55)'
    pCtx.fillRect(0,        0,        C,   OFF)
    pCtx.fillRect(0,        OFF + SQ,  C,   OFF)
    pCtx.fillRect(0,        OFF,       OFF,  SQ)
    pCtx.fillRect(OFF + SQ, OFF,       OFF,  SQ)
    pCtx.strokeStyle = 'rgba(255,255,255,0.85)'
    pCtx.lineWidth = 2
    pCtx.strokeRect(OFF + 1, OFF + 1, SQ - 2, SQ - 2)
    pCtx.strokeStyle = 'white'
    pCtx.lineWidth = 3
    const cs = 14
    for (const [cx, cy] of [[OFF, OFF], [OFF+SQ, OFF], [OFF, OFF+SQ], [OFF+SQ, OFF+SQ]] as [number,number][]) {
      const sx = cx === OFF ? 1 : -1, sy = cy === OFF ? 1 : -1
      pCtx.beginPath()
      pCtx.moveTo(cx + sx * cs, cy); pCtx.lineTo(cx, cy); pCtx.lineTo(cx, cy + sy * cs)
      pCtx.stroke()
    }
  }

  function clamp() {
    const w = srcImg.naturalWidth * scale, h = srcImg.naturalHeight * scale
    ox = Math.max(OFF + SQ - w, Math.min(OFF, ox))
    oy = Math.max(OFF + SQ - h, Math.min(OFF, oy))
  }

  preview.addEventListener('mousedown', e => { dragging = true; dx = e.clientX - ox; dy = e.clientY - oy })
  window.addEventListener('mousemove',  e => { if (!dragging) return; ox = e.clientX - dx; oy = e.clientY - dy; clamp(); draw() })
  window.addEventListener('mouseup',    () => { dragging = false })

  preview.addEventListener('touchstart', e => {
    e.preventDefault(); dragging = true
    dx = e.touches[0].clientX - ox; dy = e.touches[0].clientY - oy
  }, { passive: false })
  window.addEventListener('touchmove', e => {
    if (!dragging) return; e.preventDefault()
    ox = e.touches[0].clientX - dx; oy = e.touches[0].clientY - dy; clamp(); draw()
  }, { passive: false })
  window.addEventListener('touchend', () => { dragging = false })

  function closeCrop() {
    modal.style.display = 'none'
    errorEl.classList.add('hidden')
    fileInput.value = ''
  }
  cancelBtn.addEventListener('click', closeCrop)
  closeBtn.addEventListener('click',  closeCrop)

  confirmBtn.addEventListener('click', async () => {
    confirmBtn.textContent = 'Subiendo...'
    confirmBtn.setAttribute('disabled', 'true')
    try {
      const srcX = (OFF - ox) / scale, srcY = (OFF - oy) / scale, srcS = SQ / scale
      oCtx.clearRect(0, 0, 400, 400)
      oCtx.drawImage(srcImg, srcX, srcY, srcS, srcS, 0, 0, 400, 400)
      const blob = await new Promise<Blob>(res => output.toBlob(b => res(b!), 'image/jpeg', 0.92))
      const fd = new FormData()
      fd.append('avatar', blob, 'avatar.jpg')
      const resp = await fetch('/api/profile/avatar', { method: 'POST', body: fd })
      const json = await resp.json()
      if (!resp.ok) throw new Error(json.error ?? 'Error')
      const prev = document.getElementById('avatar-preview')
      if (prev instanceof HTMLImageElement) {
        prev.src = json.url
      } else {
        const img = Object.assign(document.createElement('img'), {
          id: 'avatar-preview', src: json.url, alt: 'avatar',
          className: 'w-16 h-16 rounded-full object-cover border-2'
        })
        img.style.borderColor = '#D9C3A5'
        prev?.replaceWith(img)
      }
      closeCrop()
    } catch (err: any) {
      errorEl.textContent = err.message ?? 'Error al subir'
      errorEl.classList.remove('hidden')
    } finally {
      confirmBtn.textContent = 'Confirmar'
      confirmBtn.removeAttribute('disabled')
    }
  })
</script>
