---
import HostLayout from '../../layouts/HostLayout.astro'
import { getSessionUser, supabaseAdmin } from '../../lib/supabase'

const { user, profile } = await getSessionUser(Astro.cookies)
if (!user) return Astro.redirect('/auth/login')

let success = false
let error   = ''

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData()
  const { error: e } = await supabaseAdmin
    .from('profiles')
    .update({ full_name: form.get('full_name')?.toString(), phone: form.get('phone')?.toString() })
    .eq('id', user.id)
  if (e) error = 'Error al guardar.'
  else success = true
}
---

<HostLayout title="Mi Perfil" active="/host/profile">
  <div class="max-w-lg mx-auto">
    {success && <div class="mb-5 px-4 py-3 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100">Perfil actualizado.</div>}
    {error && <div class="mb-5 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100">{error}</div>}

    <div class="bg-white border rounded-2xl p-6" style="border-color:#e8ddd4">
      <div class="flex items-center gap-4 mb-6 pb-6 border-b" style="border-color:#e8ddd4">
        <div class="w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold text-white" style="background-color:#2E593F">
          {(profile?.full_name ?? user.email ?? 'H')[0].toUpperCase()}
        </div>
        <div>
          <p class="font-semibold text-gray-900">{profile?.full_name ?? '(sin nombre)'}</p>
          <p class="text-sm text-gray-400">{user.email}</p>
        </div>
      </div>
      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Nombre completo</label>
          <input name="full_name" type="text" value={profile?.full_name ?? ''}
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none" style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Teléfono</label>
          <input name="phone" type="tel" value={profile?.phone ?? ''} placeholder="+56 9 1234 5678"
            class="w-full px-4 py-3 rounded-xl border text-sm outline-none placeholder:text-gray-400" style="border-color:#D9C3A5" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
          <input type="email" value={user.email} disabled
            class="w-full px-4 py-3 rounded-xl border text-sm bg-gray-50 text-gray-400" style="border-color:#D9C3A5" />
        </div>
        <button type="submit"
          class="w-full py-3.5 rounded-xl text-white text-sm font-semibold hover:opacity-90 transition"
          style="background-color:#6D4C3D">
          Guardar cambios
        </button>
      </form>
    </div>
  </div>
</HostLayout>
